{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=LienHoaApp_Mega;Username=admin;Password=admin"
  },
  "Jwt": {
    "Issuer": "LienHoaApp.Account",
    "Audience": "LienHoaApp",
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharsLong!!"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": true,
    "AllowedEnvironments": [
      "Development",
      "Staging"
    ],
    "UiProvider": "Both",
    "Title": "LHA Mega Service",
    "Description": "Mega Service API.",
    "Version": "v1",
    "ContactName": "LienHoa Platform Team",
    "ContactEmail": "platform@lienhoaapp.com",
    "SecuritySchemes": [
      {
        "Name": "Bearer",
        "Type": "Http",
        "Scheme": "bearer",
        "BearerFormat": "JWT",
        "Description": "Enter your JWT access token."
      }
    ],
    "Metadata": {
      "service": "mega",
      "team": "platform"
    }
  }
}