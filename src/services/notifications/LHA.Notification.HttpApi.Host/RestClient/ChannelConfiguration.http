@host = https://localhost:7199
@token = Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..jf0btVecb8xmtUNeex36LWuZrNfccYVYxD6lZO0AKLE
@tenantId = 00000000-0000-0000-0000-000000000000
@version = 1

# ==============================================================================
# CHANNEL CONFIGURATIONS
# ==============================================================================

@configId = 00000000-0000-0000-0000-000000000000

### Get Paged Channel Configurations (Super Admin)
GET {{host}}/api/v{{version}}/notification/configurations?tenantId={{tenantId}}&pageNumber=1&pageSize=20&isEnabled=true
Authorization: {{token}}

### Get Channel Configuration by ID
GET {{host}}/api/v{{version}}/notification/configurations/{{configId}}?tenantId={{tenantId}}
Authorization: {{token}}

### Get Channel Configuration by Channel (with Tenant fallback)
GET {{host}}/api/v{{version}}/notification/configurations/channel/Email?tenantId={{tenantId}}
Authorization: {{token}}

### Get Current Channel Configuration (uses ICurrentTenant automatically)
GET {{host}}/api/v{{version}}/notification/configurations/current/Email
Authorization: {{token}}

### Create Channel Configuration
POST {{host}}/api/v{{version}}/notification/configurations?tenantId={{tenantId}}
Authorization: {{token}}
Content-Type: application/json

{
  "channel": "Email",
  "providerType": "Smtp",
  "isEnabled": true,
  "settings": {
    "host": "smtp.mailtrap.io",
    "port": "2525",
    "userName": "user",
    "password": "password",
    "enableSsl": "true"
  }
}

### Update Channel Configuration
PUT {{host}}/api/v{{version}}/notification/configurations/{{configId}}
Authorization: {{token}}
Content-Type: application/json

{
  "channel": "Email",
  "providerType": "Smtp",
  "isEnabled": true,
  "settings": {
    "host": "smtp.updated.io",
    "port": "587",
    "userName": "user",
    "password": "newpassword",
    "enableSsl": "true"
  }
}

### Enable Channel Configuration
POST {{host}}/api/v{{version}}/notification/configurations/{{configId}}/enable
Authorization: {{token}}

### Disable Channel Configuration
POST {{host}}/api/v{{version}}/notification/configurations/{{configId}}/disable
Authorization: {{token}}

### Delete Channel Configuration
DELETE {{host}}/api/v{{version}}/notification/configurations/{{configId}}
Authorization: {{token}}
