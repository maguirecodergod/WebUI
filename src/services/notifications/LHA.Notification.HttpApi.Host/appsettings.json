{
  "ConnectionStrings": {
    "Default": "mongodb://root:admin@localhost:27017/LHA_Notification?authSource=admin",
    "Redis": "localhost:6379"
  },
  "MongoDB": {
    "DatabaseName": "LHA_Notification"
  },
  "Redis": {
    "InstanceName": "notification:",
    "Database": 1
  },
  "AccountService": {
    "GrpcUrl": "https://localhost:8150"
  },
  "Notification": {
    "Email": {
      "Smtp": {
        "Host": "localhost",
        "Port": 587,
        "Username": "",
        "Password": "",
        "UseSsl": true,
        "FromEmail": "noreply@lha.com",
        "FromName": "LHA Notification"
      },
      "SendGrid": {
        "ApiKey": "SG.placeholder",
        "FromEmail": "noreply@lha.com"
      }
    },
    "Sms": {
      "Twilio": {
        "AccountSid": "AC.placeholder",
        "AuthToken": "token.placeholder",
        "FromPhoneNumber": "+1234567890"
      }
    },
    "Push": {
      "Fcm": {
        "ProjectId": "lha-notification",
        "ServiceAccountJson": "{}"
      },
      "Apns": {
        "BundleId": "com.lha.notification",
        "P8Certificate": "",
        "KeyId": "",
        "TeamId": ""
      }
    },
    "WebPush": {
      "PublicKey": "placeholder",
      "PrivateKey": "placeholder",
      "Subject": "mailto:admin@lha.com"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "LienHoaApp.Account",
    "Audience": "LienHoaApp",
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharsLong!!",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "https://localhost:7199",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "https://localhost:8199",
        "Protocols": "Http2"
      }
    }
  },
  "Swagger": {
    "Enabled": true,
    "AllowedEnvironments": [
      "Development",
      "Staging"
    ],
    "UiProvider": "Both",
    "Title": "LHA Notification Service",
    "Description": "LHA Notification Service",
    "Version": "v1",
    "SecuritySchemes": [
      {
        "Name": "Bearer",
        "Type": "Http",
        "Scheme": "bearer",
        "BearerFormat": "JWT",
        "Description": "Enter your JWT access token."
      }
    ],
    "Metadata": {
      "service": "notification",
      "team": "platform"
    }
  }
}