{
  "ConnectionStrings": {
    "Default": "mongodb://admin:admin@localhost:27017/LHA_Notification?authSource=admin"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "LienHoaApp.Account",
    "Audience": "LienHoaApp",
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharsLong!!",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "https://localhost:7199",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "https://localhost:8199",
        "Protocols": "Http2"
      }
    }
  },
  "Swagger": {
    "Enabled": true,
    "AllowedEnvironments": [
      "Development",
      "Staging"
    ],
    "UiProvider": "Both",
    "Title": "LHA Notification Service",
    "Description": "LHA Notification Service",
    "Version": "v1",
    "SecuritySchemes": [
      {
        "Name": "Bearer",
        "Type": "Http",
        "Scheme": "bearer",
        "BearerFormat": "JWT",
        "Description": "Enter your JWT access token."
      }
    ],
    "Metadata": {
      "service": "notification",
      "team": "platform"
    }
  }
}