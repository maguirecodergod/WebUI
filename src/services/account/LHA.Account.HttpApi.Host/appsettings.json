{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=LienHoaApp_Account;Username=admin;Password=admin"
  },
  "Jwt": {
    "Issuer": "LienHoaApp.Account",
    "Audience": "LienHoaApp",
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharsLong!!",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5150",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://localhost:5151",
        "Protocols": "Http2"
      }
    }
  },
  "Swagger": {
    "Enabled": true,
    "AllowedEnvironments": [
      "Development",
      "Staging"
    ],
    "UiProvider": "Both",
    "Title": "LHA Account Service",
    "Description": "Composite host for Identity, Tenant Management, Audit Log & Permission Management.",
    "Version": "v1",
    "ContactName": "LienHoa Platform Team",
    "ContactEmail": "platform@lienhoaapp.com",
    "SecuritySchemes": [
      {
        "Name": "Bearer",
        "Type": "Http",
        "Scheme": "bearer",
        "BearerFormat": "JWT",
        "Description": "Enter your JWT access token."
      }
    ],
    "Metadata": {
      "service": "account",
      "team": "platform"
    }
  }
}