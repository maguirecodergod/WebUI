{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/v1/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/identity/{**catch-all}"
          }
        ]
      },
      "tenant-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/v1/tenant-management/{**catch-all}"
        }
      },
      "permission-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/v1/permission-management/{**catch-all}"
        }
      },
      "audit-log-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/v1/audit-log/{**catch-all}"
        }
      },
      "account-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/v1/account/{**catch-all}"
        }
      },
      "mega-route": {
        "ClusterId": "mega-cluster",
        "Match": {
          "Path": "/api/v1/mega/{**catch-all}"
        }
      },
      "movie-route": {
        "ClusterId": "movie-cluster",
        "Match": {
          "Path": "/api/v1/movie/{**catch-all}"
        }
      },
      "account-grpc-route": {
        "ClusterId": "account-grpc-cluster",
        "Match": {
          "Path": "/LHA.Grpc.Contracts.Services.Account.V1.PermissionRegistrationService/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7151"
          }
        }
      },
      "tenant-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7152"
          }
        }
      },
      "permission-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7153"
          }
        }
      },
      "audit-log-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7154"
          }
        }
      },
      "account-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7150"
          }
        }
      },
      "mega-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7156"
          }
        }
      },
      "movie-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7157"
          }
        }
      },
      "account-grpc-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:8150"
          }
        },
        "HttpRequest": {
          "Version": "2",
          "VersionPolicy": "RequestVersionExact"
        }
      }
    }
  },
  "Swagger": {
    "Enabled": true,
    "Title": "LHA API Gateway",
    "Version": "v1",
    "OpenApiRoutePrefix": "openapi",
    "SwaggerUiRoutePrefix": "swagger",
    "ScalarRoutePrefix": "scalar"
  },
  "Authentication": {
    "Authority": "https://localhost:7151",
    "Audience": "gateway",
    "RequireHttpsMetadata": false
  },
  "RateLimiting": {
    "GlobalRateLimit": 100,
    "GlobalWindowSeconds": 60
  }
}
