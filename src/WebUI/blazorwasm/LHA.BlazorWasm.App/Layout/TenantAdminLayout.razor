            Id = "ta-dashboard",
            TitleKey = "Sidebar.Dashboard",
            Href = "/dashboard",
            MatchMode = CNavLinkMatchMode.Exact,
            Icon = """<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>"""
        },
        new() { IsDivider = true, TitleKey = "Content" },
        new()
        {
            Id = "ta-movies",
            TitleKey = "Sidebar.Movies",
            Href = "/movies",
            Icon = """<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>"""
        },
        new()
        {
            Id = "ta-actors",
