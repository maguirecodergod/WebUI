            Badge = "β"
        }
    };

    private void ToggleSidebar()
    {
        if (_sidebarState == CSidebarState.Hidden)
        {
            _sidebar?.ToggleMobileDrawer();
        }
        else
        {
            _sidebarState = _sidebarState == CSidebarState.Expanded
                ? CSidebarState.Mini
                : CSidebarState.Expanded;
        }
    }

    private void OnSidebarItemClick(SidebarItemModel item)
    {
        // Optional: handle additional sidebar item click logic
    }

    protected override void OnInitialized()
    {
        ThemeState.OnThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged(CThemeMode mode)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        ThemeState.OnThemeChanged -= OnThemeChanged;
    }
}
