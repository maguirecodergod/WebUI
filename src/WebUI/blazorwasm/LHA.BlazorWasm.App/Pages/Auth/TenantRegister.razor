@page "/register-tenant"
@layout EmptyLayout
@inherits LhaComponentBase
@using LHA.TenantManagement.Domain.Shared
@using LHA.Shared.Contracts.Identity.Auth
@using LHA.BlazorWasm.HttpApi.Client.Clients
@using LHA.BlazorWasm.HttpApi.Client.Core
@using LHA.BlazorWasm.Services.Auth
@using LHA.BlazorWasm.Components.Forms
@using LHA.BlazorWasm.Components.Form
@using LHA.BlazorWasm.Components.Buttons
@inject NavigationManager NavManager
@inject AuthApiClient AuthClient
@inject ApiAuthenticationStateProvider AuthStateProvider
@inject LHA.BlazorWasm.Services.Theme.IThemeService ThemeService
@inject LHA.BlazorWasm.Services.Theme.ThemeState ThemeState

<PageTitle>@Localizer.L("TenantRegister.Title")</PageTitle>

<div class="register-container @ThemeService.ThemeClass">
    @* Background elements for glassmorphism ambient glow *@
    <div class="ambient-glow glow-1"></div>
    <div class="ambient-glow glow-2"></div>

    <div class="register-glass-panel">
        <div class="register-header">
            <h1 class="brand-title">LHA<span class="brand-accent">App</span></h1>
            <p class="subtitle">@Localizer.L("TenantRegister.Subtitle")</p>
        </div>

        <div class="wizard-steps">
            <div class="step @(CurrentStep == 1 ? "active" : (CurrentStep > 1 ? "completed" : ""))">
                <div class="step-circle">1</div>
                <div class="step-text">@Localizer.L("TenantRegister.Steps.Plan")</div>
            </div>
            <div class="step-line @(CurrentStep > 1 ? "completed" : "")"></div>
            <div class="step @(CurrentStep == 2 ? "active" : (CurrentStep > 2 ? "completed" : ""))">
                <div class="step-circle">2</div>
                <div class="step-text">@Localizer.L("TenantRegister.Steps.Details")</div>
            </div>
            <div class="step-line @(CurrentStep > 2 ? "completed" : "")"></div>
            <div class="step @(CurrentStep == 3 ? "active" : "")">
                <div class="step-circle">3</div>
                <div class="step-text">@Localizer.L("TenantRegister.Steps.Launch")</div>
            </div>
        </div>

        <div class="wizard-content">
            @if (CurrentStep == 1)
            {
                <div class="step-1-plans">
                    <h2 class="section-title">@Localizer.L("TenantRegister.Step1.Title")</h2>
                    <p class="section-desc">@Localizer.L("TenantRegister.Step1.Desc")</p>

                    <div class="plans-grid">
                        @* Basic / Shared Plan *@
                        <div class="plan-card @(SelectedStyle == CMultiTenancyDatabaseStyle.Shared ? "selected" : "")"
                        @onclick="() => SelectedStyle = CMultiTenancyDatabaseStyle.Shared">
                            <div class="plan-badge">@Localizer.L("TenantRegister.Step1.BadgePopular")</div>
                            <div class="plan-icon plan-icon-blue">
                                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2"
                                    fill="none">
                                    <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                                </svg>
                            </div>
                            <h3>@Localizer.L("TenantRegister.Step1.PlanStartup.Name")</h3>
                            <div class="plan-subtitle">@Localizer.L("TenantRegister.Step1.PlanStartup.Subtitle")</div>
                            <p class="plan-desc">@Localizer.L("TenantRegister.Step1.PlanStartup.Desc")</p>
                            <div class="plan-price">@Localizer.L("TenantRegister.Step1.PlanStartup.Price")<span>/mo</span></div>
                            <ul class="plan-features">
                                <li>@Localizer.L("TenantRegister.Step1.PlanStartup.Feature1")</li>
                                <li>@Localizer.L("TenantRegister.Step1.PlanStartup.Feature2")</li>
                                <li>@Localizer.L("TenantRegister.Step1.PlanStartup.Feature3")</li>
                            </ul>
                        </div>

                        @* Hybrid Plan *@
                        <div class="plan-card @(SelectedStyle == CMultiTenancyDatabaseStyle.Hybrid ? "selected" : "")"
                        @onclick="() => SelectedStyle = CMultiTenancyDatabaseStyle.Hybrid">
                            <div class="plan-icon plan-icon-purple">
                                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2"
                                    fill="none">
                                    <circle cx="12" cy="12" r="3"></circle>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                </svg>
                            </div>
                            <h3>@Localizer.L("TenantRegister.Step1.PlanBusiness.Name")</h3>
                            <div class="plan-subtitle">@Localizer.L("TenantRegister.Step1.PlanBusiness.Subtitle")</div>
                            <p class="plan-desc">@Localizer.L("TenantRegister.Step1.PlanBusiness.Desc")</p>
                            <div class="plan-price">@Localizer.L("TenantRegister.Step1.PlanBusiness.Price")<span>/mo</span></div>
                            <ul class="plan-features">
                                <li>@Localizer.L("TenantRegister.Step1.PlanBusiness.Feature1")</li>
                                <li>@Localizer.L("TenantRegister.Step1.PlanBusiness.Feature2")</li>
                                <li>@Localizer.L("TenantRegister.Step1.PlanBusiness.Feature3")</li>
                            </ul>
                        </div>

                        @* Dedicated Plan *@
                        <div class="plan-card @(SelectedStyle == CMultiTenancyDatabaseStyle.PerTenant ? "selected" : "")"
                        @onclick="() => SelectedStyle = CMultiTenancyDatabaseStyle.PerTenant">
                            <div class="plan-icon plan-icon-gold">
                                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2"
                                    fill="none">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <h3>@Localizer.L("TenantRegister.Step1.PlanEnterprise.Name")</h3>
                            <div class="plan-subtitle">@Localizer.L("TenantRegister.Step1.PlanEnterprise.Subtitle")</div>
                            <p class="plan-desc">@Localizer.L("TenantRegister.Step1.PlanEnterprise.Desc")</p>
                            <div class="plan-price">@Localizer.L("TenantRegister.Step1.PlanEnterprise.Price")<span>/mo</span></div>
                            <ul class="plan-features">
                                <li>@Localizer.L("TenantRegister.Step1.PlanEnterprise.Feature1")</li>
                                <li>@Localizer.L("TenantRegister.Step1.PlanEnterprise.Feature2")</li>
                                <li>@Localizer.L("TenantRegister.Step1.PlanEnterprise.Feature3")</li>
                            </ul>
                        </div>
                    </div>

                    <div class="wizard-actions right-align">
                        <Button Style="CButtonStyle.Primary" Size="CButtonSize.Large" OnClick="NextStep" Class="btn-primary-neon">
                            @Localizer.L("TenantRegister.Step1.Continue") <span class="arrow">→</span>
                        </Button>
                    </div>
                </div>
            }
            else if (CurrentStep == 2)
            {
                <div class="step-2-details form-animate">
                    <h2 class="section-title">@Localizer.L("TenantRegister.Step2.Title")</h2>
                    <p class="section-desc">@string.Format(Localizer.L("TenantRegister.Step2.Desc"), SelectedStyle)</p>

                    <EditForm Model="@Model" OnValidSubmit="NextStep">
                        <FluentValidationValidator />
                        <ServerSideValidator @ref="_serverValidator" />

                        <div class="form-grid">
                            <FormField Label="@Localizer.L("TenantRegister.Step2.OrgName")" Required="true" Class="full-width" 
                                       ValueExpression="@(() => (object)Model.TenantName)">
                                <CInput @bind-Value="Model.TenantName" Placeholder="e.g., Acme Corp.">
                                    <IconContent>
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="9" y1="3" x2="9" y2="21"></line>
                                        </svg>
                                    </IconContent>
                                </CInput>
                            </FormField>

                            <FormField Label="@Localizer.L("TenantRegister.Step2.AdminUsername")" Required="true" 
                                       ValueExpression="@(() => (object)Model.AdminUserName)">
                                <CInput @bind-Value="Model.AdminUserName" Placeholder="admin">
                                    <IconContent>
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                            <circle cx="12" cy="7" r="4"></circle>
                                        </svg>
                                    </IconContent>
                                </CInput>
                            </FormField>

                            <FormField Label="@Localizer.L("TenantRegister.Step2.AdminEmail")" Required="true" 
                                       ValueExpression="@(() => (object)Model.AdminEmail)">
                                <CInput @bind-Value="Model.AdminEmail" Type="email" Placeholder="admin@acme.com">
                                    <IconContent>
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                            <polyline points="22,6 12,13 2,6"></polyline>
                                        </svg>
                                    </IconContent>
                                </CInput>
                            </FormField>

                            <FormField Label="@Localizer.L("TenantRegister.Step2.AdminPassword")" Required="true" Class="full-width" 
                                       ValueExpression="@(() => (object)Model.AdminPassword)">
                                <CInput @bind-Value="Model.AdminPassword" Type="password" Placeholder="••••••••">
                                    <IconContent>
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                        </svg>
                                    </IconContent>
                                </CInput>
                            </FormField>
                        </div>

                        <div class="wizard-actions space-between mt-8">
                            <Button Style="CButtonStyle.Ghost" OnClick="PrevStep" Class="btn-secondary-ghost">
                                <span class="arrow">←</span> @Localizer.L("TenantRegister.Step2.Back")
                            </Button>
                            <Button Type="CButtonType.Submit" Style="CButtonStyle.Primary" Class="btn-primary-neon">
                                @Localizer.L("TenantRegister.Step2.Finalize") <span class="arrow">→</span>
                            </Button>
                        </div>
                    </EditForm>
                </div>
            }
            else if (CurrentStep == 3)
            {
                <div class="step-3-success form-animate">
                    <div class="success-icon-wrapper">
                        <svg class="success-icon checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                            <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none" />
                            <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
                        </svg>
                    </div>
                    <h2 class="section-title text-center">@Localizer.L("TenantRegister.Step3.Title")</h2>
                    <p class="section-desc text-center">@string.Format(Localizer.L("TenantRegister.Step3.Desc"), Model.TenantName, SelectedStyle)</p>

                    <div class="launch-loader">
                        <div class="progress-bar-neon"></div>
                    </div>

                    <div class="wizard-actions center-align mt-8">
                        <Button Style="CButtonStyle.Primary" OnClick="GoToDashboard" Class="btn-primary-neon">@Localizer.L("TenantRegister.Step3.Launch")</Button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        ThemeState.OnThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged(LHA.BlazorWasm.Services.Theme.CThemeMode mode)
    {
        InvokeAsync(StateHasChanged);
    }

    public override void Dispose()
    {
        base.Dispose();
        ThemeState.OnThemeChanged -= OnThemeChanged;
    }

    private int CurrentStep = 1;



    private CMultiTenancyDatabaseStyle SelectedStyle { get; set; } = CMultiTenancyDatabaseStyle.Shared;

    private RegisterTenantInput Model { get; set; } = new();



    private ServerSideValidator _serverValidator = default!;

    private async Task NextStep()
    {
        if (CurrentStep < 3)
        {
            CurrentStep++;
            if (CurrentStep == 3)
            {
                StateHasChanged(); // Render the loading UI quickly

                Model.DatabaseStyle = (int)SelectedStyle;

                try
                {
                    var authResult = await AuthClient.RegisterTenantAsync(Model);
                    if (authResult != null && !string.IsNullOrEmpty(authResult.AccessToken))
                    {
                        await AuthStateProvider.MarkUserAsAuthenticatedAsync(authResult);
                        await Task.Delay(1000); 
                        GoToDashboard();
                    }
                    else
                    {
                        CurrentStep = 2; // general error, no exception
                    }
                }
                catch (ApiException ex)
                {
                    CurrentStep = 2; // Return to form to show errors
                    StateHasChanged();

                    if (ex.StatusCode == System.Net.HttpStatusCode.BadRequest || 
                        ex.StatusCode == System.Net.HttpStatusCode.UnprocessableEntity)
                    {
                        // Safely display validation errors matched by property name
                        if (ex.ApiError?.ValidationErrors != null)
                        {
                            _serverValidator.DisplayErrors(ex.ApiError.ValidationErrors);
                        }
                    }
                }
                catch (Exception)
                {
                    // Network errors or other unexpected crashes.
                    // The ToastApiErrorHandler will have shown the user a toast already.
                    CurrentStep = 2;
                    StateHasChanged();
                }
            }
            StateHasChanged();
        }
    }



    private void PrevStep()

    {

        if (CurrentStep > 1)

        {

            CurrentStep--;

            StateHasChanged();

        }

    }



    private void GoToDashboard()
    {
        NavManager.NavigateTo("/");
    }
}
