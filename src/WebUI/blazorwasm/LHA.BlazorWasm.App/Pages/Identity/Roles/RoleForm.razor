@page "/identity/roles/create"
@page "/identity/roles/{Id:guid}"
@using LHA.Shared.Contracts.Identity
@using LHA.Shared.Contracts.Identity.Roles
@using LHA.Shared.Contracts.Identity.Users
@using LHA.Shared.Contracts.Identity.Permissions
@using LHA.Shared.Contracts.PermissionManagement
@using LHA.BlazorWasm.HttpApi.Client.Clients
@using LHA.BlazorWasm.HttpApi.Client.Clients.PermissionManagement
@inherits LhaComponentBase

<PageTitle>@(IsEdit ? "Cập nhật nhóm quyền" : "Thêm mới nhóm quyền")</PageTitle>

<div class="role-form-page container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 text-muted small">
                    <li class="breadcrumb-item"><a href="/identity/roles" class="text-decoration-none">Danh sách nhóm quyền</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@(IsEdit ? "Cập nhật" : "Thêm mới")</li>
                </ol>
            </nav>
            <h1 class="h4 mb-0 fw-bold text-dark">@(IsEdit ? "Cập nhật nhóm quyền" : "Thêm mới nhóm quyền")</h1>
        </div>
        <div class="d-flex gap-2">
            <Button Style="CButtonStyle.Primary" Size="CButtonSize.Medium" OnClick="SaveAsync" IsLoading="_isSaving">
                <i class="bi bi-save me-1"></i> Lưu
            </Button>
            <Button Style="CButtonStyle.Secondary" Size="CButtonSize.Medium" OnClick="GoBack">
                Hủy
            </Button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-3 mb-4 h-100">
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Tên nhóm quyền <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" placeholder="Nhập tên nhóm quyền" @bind="RoleName" disabled="@(IsEdit && _role?.IsStatic == true)" />
                    </div>

                    <div class="mb-2 fw-bold">Người dùng</div>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Tìm kiếm theo tên người dùng" @bind="UserSearchFilter" @bind:event="oninput" @onkeyup="FilterUsers" />
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="selectAllUsers" checked="@IsAllUsersSelected" @onchange="ToggleSelectAllUsers">
                        <label class="form-check-label" for="selectAllUsers">
                            Chọn tất cả người dùng
                        </label>
                    </div>

                    <div class="d-flex flex-wrap gap-2 user-list" style="max-height: 400px; overflow-y: auto;">
                        @foreach (var user in FilteredUsers)
                        {
                            var isSelected = SelectedUserIds.Contains(user.Id);
                            <div class="user-badge px-3 py-2 border rounded cursor-pointer @(isSelected ? "selected" : "")" @onclick="() => ToggleUserSelection(user.Id)">
                                <span class="text-truncate">@user.UserName</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-7">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body">
                    <div class="mb-4 fw-bold">Nhóm quyền (Permissions)</div>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Tìm kiếm theo tên quyền" @bind="PermissionSearchFilter" @bind:event="oninput" @onkeyup="FilterPermissions" />
                    </div>

                    <div class="d-flex gap-4 mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="selectAllPerms" checked="@IsAllPermissionsSelected" @onchange="ToggleSelectAllPermissions">
                            <label class="form-check-label" for="selectAllPerms">
                                Chọn tất cả nhóm quyền
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="expandAllPerms" checked="@IsAllExpanded" @onchange="ToggleExpandAll">
                            <label class="form-check-label" for="expandAllPerms">
                                Mở tất cả nhóm quyền
                            </label>
                        </div>
                    </div>

                    <div class="permission-tree" style="max-height: 600px; overflow-y: auto;">
                        @foreach (var group in FilteredPermissionGroups)
                        {
                            var hasCheckedChild = group.Permissions.Any(p => SelectedPermissions.Contains(p.Name));
                            var allChecked = group.Permissions.All(p => SelectedPermissions.Contains(p.Name));
                            var isExpanded = ExpandedGroups.Contains(group.Name);

                            <div class="permission-group mb-3 border rounded p-3 @(hasCheckedChild ? "border-primary-subtle bg-light" : "")">
                                <div class="d-flex align-items-center">
                                    <button class="btn btn-sm btn-link p-0 me-2 text-dark text-decoration-none" @onclick="() => ToggleExpandGroup(group.Name)">
                                        <i class="bi @(isExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                    </button>
                                    
                                    <div class="form-check mb-0 flex-grow-1">
                                        <input class="form-check-input" type="checkbox" id="group_@group.Name" 
                                               checked="@allChecked" 
                                               indeterminate="@(hasCheckedChild && !allChecked)"
                                               @onchange="(e) => ToggleGroupPermissions(group, (bool)(e.Value ?? false))">
                                        <label class="form-check-label fw-semibold cursor-pointer select-none" for="group_@group.Name">
                                            @group.DisplayName
                                        </label>
                                    </div>
                                </div>

                                @if (isExpanded)
                                {
                                    <div class="permission-items mt-3 ms-4 ps-3 border-start">
                                        @foreach (var perm in group.Permissions)
                                        {
                                            var isPermSelected = SelectedPermissions.Contains(perm.Name);
                                            <div class="form-check mb-2">
                                                <input class="form-check-input" type="checkbox" id="perm_@perm.Name" 
                                                       checked="@isPermSelected" 
                                                       @onchange="(e) => TogglePermission(perm.Name, (bool)(e.Value ?? false))">
                                                <label class="form-check-label cursor-pointer" for="perm_@perm.Name">
                                                    @perm.DisplayName
                                                    @if (!string.IsNullOrEmpty(perm.Description))
                                                    {
                                                        <div class="small text-muted">@perm.Description</div>
                                                    }
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .select-none { user-select: none; }
    .user-badge {
        transition: all 0.2s ease;
        background: #f8f9fa;
        color: #495057;
        border-color: #dee2e6 !important;
    }
    .user-badge:hover {
        background: #e9ecef;
    }
    .user-badge.selected {
        background: #e7f5ff;
        color: #0b5ed7;
        border-color: #9ec5fe !important;
    }
</style>

@code {
    [Parameter] public Guid? Id { get; set; }
    
    [Inject] private RoleApiClient RoleService { get; set; } = default!;
    [Inject] private UserApiClient UserService { get; set; } = default!;
    [Inject] private PermissionGroupApiClient PermissionGroupService { get; set; } = default!;
    [Inject] private PermissionApiClient PermissionApiClientService { get; set; } = default!;

    private bool IsEdit => Id.HasValue;
    private bool _isSaving;

    private IdentityRoleDto? _role;
    private string RoleName { get; set; } = string.Empty;

    // Users
    private string UserSearchFilter { get; set; } = string.Empty;
    private List<IdentityUserDto> AllUsers { get; set; } = new();
    private List<IdentityUserDto> FilteredUsers => string.IsNullOrWhiteSpace(UserSearchFilter) 
        ? AllUsers 
        : AllUsers.Where(u => u.UserName.Contains(UserSearchFilter, StringComparison.OrdinalIgnoreCase)).ToList();
    private HashSet<Guid> SelectedUserIds { get; set; } = new();
    private bool IsAllUsersSelected => FilteredUsers.Any() && SelectedUserIds.IsSupersetOf(FilteredUsers.Select(u => u.Id));

    // Permissions
    private string PermissionSearchFilter { get; set; } = string.Empty;
    private List<PermissionGroupDto> AllPermissionGroups { get; set; } = new();
    private List<PermissionGroupDto> FilteredPermissionGroups => string.IsNullOrWhiteSpace(PermissionSearchFilter)
        ? AllPermissionGroups
        : AllPermissionGroups.Where(g => g.DisplayName.Contains(PermissionSearchFilter, StringComparison.OrdinalIgnoreCase) 
                                      || g.Permissions.Any(p => p.DisplayName.Contains(PermissionSearchFilter, StringComparison.OrdinalIgnoreCase))).ToList();
    
    private HashSet<string> SelectedPermissions { get; set; } = new();
    private HashSet<string> ExpandedGroups { get; set; } = new();
    private bool IsAllExpanded;
    
    private bool IsAllPermissionsSelected 
    {
        get 
        {
            var allPerms = AllPermissionGroups.SelectMany(g => g.Permissions).Select(p => p.Name).ToList();
            return allPerms.Any() && SelectedPermissions.IsSupersetOf(allPerms);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            // 1. Fetch Users
            var usersResult = await UserService.GetListAsync(new GetIdentityUsersInput { PageSize = 1000, PageNumber = 1 });
            if (usersResult != null) AllUsers = usersResult.Items.ToList();

            // 2. Fetch Permission Groups
            var groupsResult = await PermissionGroupService.GetListAsync(new GetPermissionGroupsInput { PageSize = 1000, PageNumber = 1 });
            if (groupsResult != null) AllPermissionGroups = groupsResult.Items.ToList();

            // 3. If Edit, fetch Role & its configurations
            if (IsEdit)
            {
                _role = await RoleService.GetAsync(Id!.Value);
                if (_role != null)
                {
                    RoleName = _role.Name;
                    
                    // Set users who have this role
                    foreach (var user in AllUsers)
                    {
                        if (user.Roles.Any(r => r.RoleId == _role.Id || r.RoleName == _role.Name))
                        {
                            SelectedUserIds.Add(user.Id);
                        }
                    }

                    // Fetch Permissions for this role
                    var grants = await PermissionApiClientService.GetAsync(new GetPermissionListInput 
                    { 
                        ProviderName = "R", 
                        ProviderKey = _role.Name 
                    });

                    if (grants != null)
                    {
                        foreach (var grant in grants.Where(g => g.IsGranted))
                        {
                            SelectedPermissions.Add(grant.Name);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            ToastNotification.Error("Lỗi tải dữ liệu: " + ex.Message);
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/identity/roles");
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(RoleName))
        {
            ToastNotification.Warning("Vui lòng nhập tên nhóm quyền.");
            return;
        }

        _isSaving = true;
        try
        {
            IdentityRoleDto? savedRole = _role;
            
            // 1. Save Role
            if (IsEdit)
            {
                // Only update if not static to prevent bugs
                if (_role!.IsStatic == false && _role.Name != RoleName) 
                {
                    savedRole = await RoleService.UpdateAsync(Id!.Value, new UpdateIdentityRoleInput 
                    { 
                        Name = RoleName,
                        ConcurrencyStamp = _role.ConcurrencyStamp
                    });
                }
            }
            else
            {
                savedRole = await RoleService.CreateAsync(new CreateIdentityRoleInput { Name = RoleName });
            }

            if (savedRole == null) return;

            // 2. Save Permissions
            var updatePermsInput = new UpdatePermissionsInput
            {
                ProviderName = "R",
                ProviderKey = savedRole.Name,
                Permissions = AllPermissionGroups
                    .SelectMany(g => g.Permissions)
                    .Select(p => new PermissionGrantInput 
                    { 
                        Name = p.Name, 
                        IsGranted = SelectedPermissions.Contains(p.Name) 
                    }).ToList()
            };
            
            await PermissionApiClientService.UpdateAsync(updatePermsInput);

            // 3. Save Users (This is a simplified approach, normally updating roles per user is expensive in a loop)
            // But for mockup/small scale it's fine. We only update changed users if possible, or skip in MVP.
            // For now, we omit doing all user updates to avoid large API latency, or we update them.
            // Actually, we should update the users.
            foreach (var user in AllUsers)
            {
                var hasRoleCurrent = user.Roles.Any(r => r.RoleName == savedRole.Name);
                var shouldHaveRole = SelectedUserIds.Contains(user.Id);
                
                if (hasRoleCurrent != shouldHaveRole)
                {
                    List<Guid> newRoleIds = user.Roles.Select(r => r.RoleId).ToList();
                    if (shouldHaveRole)
                    {
                        newRoleIds.Add(savedRole.Id);
                    }
                    else
                    {
                        newRoleIds.Remove(savedRole.Id);
                    }
                    await UserService.UpdateRolesAsync(user.Id, newRoleIds);
                }
            }

            ToastNotification.Success(IsEdit ? "Cập nhật thành công!" : "Thêm mới thành công!");
            Navigation.NavigateTo("/identity/roles");
        }
        catch (Exception ex)
        {
            ToastNotification.Error("Lỗi lưu: " + ex.Message);
        }
        finally
        {
            _isSaving = false;
        }
    }

    // --- Users Handlers ---
    private void FilterUsers() => StateHasChanged();
    
    private void ToggleUserSelection(Guid userId)
    {
        if (SelectedUserIds.Contains(userId)) SelectedUserIds.Remove(userId);
        else SelectedUserIds.Add(userId);
    }
    
    private void ToggleSelectAllUsers(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        if (isChecked)
        {
            foreach (var u in FilteredUsers) SelectedUserIds.Add(u.Id);
        }
        else
        {
            foreach (var u in FilteredUsers) SelectedUserIds.Remove(u.Id);
        }
    }

    // --- Permissions Handlers ---
    private void FilterPermissions() => StateHasChanged();

    private void ToggleSelectAllPermissions(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        var allPerms = FilteredPermissionGroups.SelectMany(g => g.Permissions).Select(p => p.Name);
        if (isChecked)
        {
            foreach (var p in allPerms) SelectedPermissions.Add(p);
        }
        else
        {
            foreach (var p in allPerms) SelectedPermissions.Remove(p);
        }
    }
    
    private void ToggleExpandAll(ChangeEventArgs e)
    {
        IsAllExpanded = (bool)(e.Value ?? false);
        if (IsAllExpanded)
        {
            foreach (var g in AllPermissionGroups) ExpandedGroups.Add(g.Name);
        }
        else
        {
            ExpandedGroups.Clear();
        }
    }

    private void ToggleExpandGroup(string groupName)
    {
        if (ExpandedGroups.Contains(groupName)) ExpandedGroups.Remove(groupName);
        else ExpandedGroups.Add(groupName);
    }

    private void ToggleGroupPermissions(PermissionGroupDto group, bool isGranted)
    {
        foreach (var p in group.Permissions)
        {
            if (isGranted) SelectedPermissions.Add(p.Name);
            else SelectedPermissions.Remove(p.Name);
        }
    }

    private void TogglePermission(string permName, bool isGranted)
    {
        if (isGranted) SelectedPermissions.Add(permName);
        else SelectedPermissions.Remove(permName);
    }
}
