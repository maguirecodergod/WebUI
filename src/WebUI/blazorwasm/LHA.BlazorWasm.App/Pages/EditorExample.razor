@page "/editor-example"
@using LHA.BlazorWasm.Components.RichTextEditor.Models

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Rich Text Editor Example</h1>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="SetDemoContent">Load Demo Content</button>
            <button class="btn btn-outline-secondary" @onclick="ClearContent">Clear</button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <RichTextEditor @bind-Value="_htmlContent" 
                                   @ref="_editor"
                                   Options="_options" />
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white font-weight-bold">
                    HTML Output
                </div>
                <div class="card-body">
                    <pre class="bg-light p-3 rounded" style="max-height: 300px; overflow-y: auto;"><code>@_htmlContent</code></pre>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white font-weight-bold">
                    Rendered Preview
                </div>
                <div class="card-body overflow-auto" style="max-height: 300px;">
                    @((MarkupString)_htmlContent)
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card { border-radius: 12px; }
    .card-header { border-top-left-radius: 12px !important; border-top-right-radius: 12px !important; }
    pre { font-size: 13px; color: #d63384; }
</style>

@code {
    private string _htmlContent = "<h3>Welcome to the LHA Rich Text Editor!</h3><p>This is a <b>full-featured</b> replacement for your standard textareas.</p><ul><li>Enterprise-grade architecture</li><li>30+ formatting tools</li><li>JS-optimized engine</li></ul>";
    
    private RichTextEditor _editor = default!;
    
    private EditorOptions _options = new()
    {
        Height = "450px",
        Placeholder = "Nhập nội dung tại đây...",
        ShowStatusBar = true
    };

    private void SetDemoContent()
    {
        _htmlContent = @"
            <h2 style='color: #1a73e8'>Premium Rich Text Experience</h2>
            <p>Xây dựng với <b>hơn 15 năm kinh nghiệm</b> trong lĩnh vực Blazor WebAssembly.</p>
            <table class='rte-table' style='border-collapse:collapse;width:100%'>
                <tr>
                    <th style='border:1px solid #ccc;padding:8px;background:#f8f9fa'>Feature</th>
                    <th style='border:1px solid #ccc;padding:8px;background:#f8f9fa'>Support</th>
                </tr>
                <tr>
                    <td style='border:1px solid #ccc;padding:8px'>Blazor WASM 10.0</td>
                    <td style='border:1px solid #ccc;padding:8px'>✅ Fully Supported</td>
                </tr>
                <tr>
                    <td style='border:1px solid #ccc;padding:8px'>Custom Dialogs</td>
                    <td style='border:1px solid #ccc;padding:8px'>✅ Included</td>
                </tr>
            </table>
            <p><br></p>
            <blockquote style='border-left: 4px solid #1a73e8; padding-left: 15px; background: #f0f7ff; padding: 10px;'>
                ""This editor is designed to be the most performant and beautiful rich text component for the LHA ecosystem.""
            </blockquote>
        ";
    }

    private void ClearContent()
    {
        _htmlContent = "";
    }
}
