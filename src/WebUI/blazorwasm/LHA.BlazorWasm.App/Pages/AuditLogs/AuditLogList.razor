@page "/audit-logs"
@inject IJSRuntime JS
@using LHA.Auditing

<PageTitle>Audit Logs</PageTitle>

<div class="audit-log-page container-fluid p-4">
    @* Page Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">Account Audit Logs</h1>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-soft-primary text-primary px-2 py-1">Account Service</span>
                <span class="text-muted small">Manage and audit system activities</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <Button Style="CButtonStyle.Secondary" Size="CButtonSize.Medium" OnClick="RefreshAsync">
                <i class="bi bi-arrow-clockwise me-1"></i> Refresh
            </Button>
            <Button Style="CButtonStyle.Danger" Size="CButtonSize.Medium" OnClick="ShowDeleteDialog">
                <i class="bi bi-trash me-1"></i> Cleanup
            </Button>
        </div>
    </div>

    @* Filters Card *@
    <div class="card shadow-sm mb-4 border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
            <h6 class="fw-bold text-muted mb-0"><i class="bi bi-filter me-2"></i>Filters</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-xl-3 col-md-6">
                    <label class="form-label small fw-semibold text-muted">Execution Date Range</label>
                    <DateRangePicker TInner="DateTimeOffset" @bind-StartDate="_input.StartTime" @bind-EndDate="_input.EndTime" />
                </div>
                <div class="col-xl-2 col-md-6">
                    <label class="form-label small fw-semibold text-muted">User Name</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                        <input type="text" class="form-control form-control-sm border-start-0 bg-light-alt" 
                               @bind="_input.UserName" placeholder="Filter by user..." />
                    </div>
                </div>
                <div class="col-xl-2 col-md-6">
                    <label class="form-label small fw-semibold text-muted">HTTP Method</label>
                    <select class="form-select form-select-sm bg-light-alt" @bind="_input.HttpMethod">
                        <option value="">All Methods</option>
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="DELETE">DELETE</option>
                    </select>
                </div>
                <div class="col-xl-3 col-md-6">
                    <label class="form-label small fw-semibold text-muted">URL Pattern</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-link-45deg"></i></span>
                        <input type="text" class="form-control form-control-sm border-start-0 bg-light-alt" 
                               @bind="_input.Url" placeholder="Search URL path..." />
                    </div>
                </div>
                <div class="col-xl-2 d-flex align-items-end">
                    <Button Style="CButtonStyle.Primary" Size="CButtonSize.Medium" Class="w-100" OnClick="SearchAsync">
                        Search
                    </Button>
                </div>
            </div>
        </div>
    </div>

    @* Data Table Card *@
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-audit-table">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3">Timestamp</th>
                            <th>Identity</th>
                            <th>Operation</th>
                            <th>Resource Path</th>
                            <th>Status</th>
                            <th>Latency</th>
                            <th class="text-end pe-4">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_loading)
                        {
                            @for (int i = 0; i < 5; i++)
                            {
                                <tr>
                                    <td class="ps-4"><Skeleton IsLoading="true" Width="120px" Height="20px" /></td>
                                    <td><Skeleton IsLoading="true" Width="150px" Height="32px" /></td>
                                    <td><Skeleton IsLoading="true" Width="60px" Height="24px" /></td>
                                    <td><Skeleton IsLoading="true" Width="250px" Height="20px" /></td>
                                    <td><Skeleton IsLoading="true" Width="50px" Height="24px" /></td>
                                    <td><Skeleton IsLoading="true" Width="70px" Height="20px" /></td>
                                    <td class="text-end pe-4"><Skeleton IsLoading="true" Width="60px" Height="30px" /></td>
                                </tr>
                            }
                        }
                        else if (!_logs.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="empty-state text-muted">
                                        <i class="bi bi-search fs-1 mb-3 d-block opacity-25"></i>
                                        <p class="mb-0">No audit logs discovered for the current selection.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var log in _logs)
                            {
                                <tr class='@(log.HttpStatusCode >= 400 ? "table-danger-light" : "")'>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@log.ExecutionTime.LocalDateTime.ToString("MMM dd, yyyy")</div>
                                        <div class="small text-muted">@log.ExecutionTime.LocalDateTime.ToString("HH:mm:ss")</div>
                                    </td>
                                    <td>
                                        @if (log.UserId.HasValue)
                                        {
                                            <div class="d-flex align-items-center">
                                                <div class="user-avatar-small me-2">
                                                    @log.UserName?[0].ToString().ToUpper()
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark small">@log.UserName</div>
                                                    <div class="text-muted" style="font-size: 0.65rem;">@log.UserId.Value.ToString().Substring(0, 8)...</div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center text-muted">
                                                <i class="bi bi-person-circle me-2 fs-5 text-muted opacity-50"></i>
                                                <span class="small font-monospace">Anonymous</span>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <span class='method-badge @log.HttpMethod?.ToLower()'>@log.HttpMethod</span>
                                    </td>
                                    <td class="url-cell">
                                        <div class="text-truncate text-muted small" style="max-width: 280px;" title="@log.Url">@log.Url</div>
                                    </td>
                                    <td>
                                        @if (log.HttpStatusCode.HasValue)
                                        {
                                            <span class='status-indicator @GetStatusType(log.HttpStatusCode.Value)'>
                                                @log.HttpStatusCode
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="duration-bar-wrap me-2">
                                                <div class='duration-bar @GetDurationType(log.ExecutionDuration)' 
                                                     style='width: @(Math.Min(log.ExecutionDuration / 10.0, 100))%;'></div>
                                            </div>
                                            <span class="small font-monospace">@log.ExecutionDuration<span class="text-muted">ms</span></span>
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-icon-view" title="View Graph" @onclick="() => ViewDetails(log)">
                                            <i class="bi bi-search"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @* Pagination Footer *@
        <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
            <div class="text-muted small">
                Showing entries <strong>@(_input.SkipCount + 1)</strong> to <strong>@(Math.Min(_input.SkipCount + _input.MaxResultCount, _totalCount))</strong> of <strong>@_totalCount</strong>
            </div>
            <div class="pagination-controls d-flex align-items-center gap-2">
                <button class='btn btn-sm btn-light border @(_currentPage == 1 ? "disabled" : "")' 
                        @onclick="() => GoToPage(_currentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div class="px-2 py-1 bg-soft-primary text-primary rounded small fw-bold">
                    Page @_currentPage
                </div>
                <button class='btn btn-sm btn-light border @(_currentPage * _input.MaxResultCount >= _totalCount ? "disabled" : "")' 
                        @onclick="() => GoToPage(_currentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@* Detailed Inspector Overlay *@
@if (_selectedLog != null)
{
    <div class="audit-inspector-overlay" @onclick="CloseDetails">
        <div class="audit-inspector-panel shadow-lg" @onclick:stopPropagation="true">
            <div class="panel-header d-flex justify-content-between align-items-center p-4 bg-dark text-white">
                <div>
                    <h5 class="mb-1">Trace Inspector</h5>
                    <div class="small opacity-75 font-monospace">CID: @_selectedLog.CorrelationId</div>
                </div>
                <button class="btn-close btn-close-white" @onclick="CloseDetails"></button>
            </div>

            <div class="panel-body p-4 bg-light-alt overflow-auto" style="flex: 1;">
                @* Summary Overview *@
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="info-tile p-3 bg-white rounded-3 shadow-sm border-start border-4 border-primary">
                            <label class="small text-muted d-block mb-1 font-monospace">ACTION</label>
                            <div class="fw-bold text-dark text-truncate" title="@_selectedLog.ActionName">@_selectedLog.ActionName</div>
                            <div class="small text-primary mt-1 fw-semibold">@_selectedLog.ApplicationName</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-tile p-3 bg-white rounded-3 shadow-sm border-start border-4 border-info">
                            <label class="small text-muted d-block mb-1 font-monospace">CLIENT</label>
                            <div class="fw-bold text-dark">@(_selectedLog.ClientIpAddress ?? "N/A")</div>
                            <div class="small text-muted mt-1 text-truncate" title="@_selectedLog.BrowserInfo">@_selectedLog.BrowserInfo</div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_selectedLog.Exceptions))
                {
                    <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">
                        <div class="fw-bold mb-2"><i class="bi bi-exclamation-triangle-fill me-2"></i>Runtime Exception Stack</div>
                        <div class="exception-container p-3 bg-dark text-light rounded border border-danger">
                             <pre class="small mb-0 text-danger-light" style="max-height: 250px; overflow: auto; font-family: 'Cascadia Code', monospace;">@_selectedLog.Exceptions</pre>
                        </div>
                    </div>
                }

                @* Tabs Section *@
                <div class="inspector-tabs card border-0 shadow-sm rounded-3 overflow-hidden">
                    <div class="card-header bg-white p-0 border-bottom">
                        <div class="nav nav-tabs nav-justified" role="tablist">
                            <button class='nav-link py-3 border-0 rounded-0 @(_activeTab == "actions" ? "active bg-light fw-bold border-bottom border-3 border-primary" : "text-muted")' 
                                    @onclick='() => _activeTab = "actions"'>
                                <i class="bi bi-lightning-charge me-2"></i>Call Stack (@_selectedLog.Actions.Count)
                            </button>
                            <button class='nav-link py-3 border-0 rounded-0 @(_activeTab == "changes" ? "active bg-light fw-bold border-bottom border-3 border-primary" : "text-muted")' 
                                    @onclick='() => _activeTab = "changes"'>
                                <i class="bi bi-database-check me-2"></i>Data Mutations (@_selectedLog.EntityChanges.Count)
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-4 bg-white">
                        @if (_activeTab == "actions")
                        {
                            <div class="timeline ps-3">
                                @if (!_selectedLog.Actions.Any())
                                {
                                    <div class="text-center text-muted py-5">No internal actions recorded.</div>
                                }
                                @foreach (var action in _selectedLog.Actions.OrderBy(x => x.ExecutionTime))
                                {
                                    <div class="timeline-item pb-4 position-relative border-start border-2 border-primary-subtle ps-4 ms-2">
                                        <div class="timeline-dot position-absolute bg-primary" style="width: 12px; height: 12px; border-radius: 50%; left: -7px; top: 5px; border: 2px solid white;"></div>
                                        <div class="timeline-content">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <h6 class="fw-bold text-dark mb-0">@action.MethodName</h6>
                                                <span class="badge bg-soft-info text-info rounded-pill px-2">@action.ExecutionDuration ms</span>
                                            </div>
                                            <div class="small text-muted font-monospace mb-2" style="font-size: 0.7rem;">@action.ServiceName</div>
                                            @if (!string.IsNullOrEmpty(action.Parameters))
                                            {
                                                <div class="params-viewer p-2 bg-light rounded border small text-muted font-monospace" style="max-height: 150px; overflow: auto;">
                                                    @action.Parameters
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="entity-changes-list">
                                @if (!_selectedLog.EntityChanges.Any())
                                {
                                    <div class="text-center text-muted py-5">
                                        <div class="mb-2"><i class="bi bi-database-dash fs-1 opacity-25"></i></div>
                                        No entity states were mutated during this trace.
                                    </div>
                                }
                                @foreach (var change in _selectedLog.EntityChanges)
                                {
                                    <div class="change-card mb-4 border rounded-3 p-3 bg-light-alt shadow-sm">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h6 class="mb-0 fw-bold text-indigo">@ExtractEntityName(change.EntityTypeFullName)</h6>
                                                <div class="small text-muted font-monospace">UUID: @change.EntityId</div>
                                            </div>
                                            <span class='badge @GetMutationTypeBadge(change.ChangeType)'>@change.ChangeType</span>
                                        </div>
                                        @if (change.PropertyChanges.Any())
                                        {
                                            <div class="table-responsive bg-white rounded border shadow-sm">
                                                <table class="table table-sm property-table mb-0 small">
                                                    <thead class="bg-light">
                                                        <tr class="text-muted" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                                            <th class="ps-3 py-2">Field</th>
                                                            <th>Previous State</th>
                                                            <th>Target State</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var p in change.PropertyChanges)
                                                        {
                                                            <tr>
                                                                <td class="ps-3 fw-bold text-dark">@p.PropertyName</td>
                                                                <td class="text-muted"><del>@p.OriginalValue</del></td>
                                                                <td class="text-success-emphasis fw-bold">@p.NewValue</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="small text-muted italic p-2 border border-dashed rounded text-center">No property-level changes captured.</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="panel-footer p-3 bg-white border-top text-end shadow-lg">
                <Button Style="CButtonStyle.Secondary" Size="CButtonSize.Medium" OnClick="CloseDetails">Dismiss Trace</Button>
            </div>
        </div>
    </div>
}

<style>
    /* ── Aesthetics & Component Variables ── */
    :root {
        --audit-bg: #f9fbff;
        --indigo-glow: rgba(99, 102, 241, 0.15);
    }
    
    .bg-light-alt { background-color: #f8fafc; }
    .text-indigo { color: #4f46e5; }
    .bg-soft-primary { background-color: #e0e7ff; }
    .bg-soft-info { background-color: #e0f2fe; }
    
    .audit-log-page { font-family: 'Outfit', 'Inter', sans-serif; }
    
    /* ── Custom Table Styles ── */
    .custom-audit-table thead th {
        font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b;
        background: #f8fafc; border-bottom: 2px solid #e2e8f0;
    }
    .custom-audit-table tbody tr { transition: background 0.15s ease; border-bottom: 1px solid #f1f5f9; }
    .custom-audit-table tbody tr:hover { background: #fefeff; box-shadow: inset 4px 0 0 #6366f1; }
    
    .url-cell .text-truncate { font-family: 'Fira Code', 'Cascadia Code', monospace; font-size: 0.8rem; }
    
    /* ── Method Badges ── */
    .method-badge {
        padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 0.7rem; text-transform: uppercase;
        display: inline-block; min-width: 55px; text-align: center;
    }
    .method-badge.get { background: #e0f2fe; color: #0369a1; }
    .method-badge.post { background: #dcfce7; color: #15803d; }
    .method-badge.put { background: #fef9c3; color: #a16207; }
    .method-badge.delete { background: #fee2e2; color: #b91c1c; }
    
    /* ── Status Indicators ── */
    .status-indicator {
        padding: 2px 10px; border-radius: 99px; font-weight: 700; font-size: 0.75rem; 
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .status-indicator.success { background: #10b981; color: white; }
    .status-indicator.warning { background: #f59e0b; color: white; }
    .status-indicator.danger { background: #ef4444; color: white; }
    
    /* ── Inspector Layout ── */
    .audit-inspector-overlay {
        position: fixed; inset: 0; background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(8px); z-index: 2100;
        display: flex; justify-content: flex-end;
    }
    .audit-inspector-panel {
        width: 100%; max-width: 850px; height: 100%; background: #f1f5f9;
        display: flex; flex-direction: column; overflow: hidden;
        box-shadow: -20px 0 50px rgba(0,0,0,0.3);
        animation: slideInRight 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .user-avatar-small {
        width: 32px; height: 32px; border-radius: 8px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white; display: flex; align-items: center; justify-content: center;
        font-weight: bold; box-shadow: 0 4px 12px var(--indigo-glow);
    }
    
    .duration-bar-wrap { width: 50px; height: 6px; background: #e2e8f0; border-radius: 10px; }
    .duration-bar { height: 100%; border-radius: 10px; }
    .duration-bar.fast { background: #10b981; }
    .duration-bar.medium { background: #f59e0b; }
    .duration-bar.slow { background: #ef4444; }
    
    .btn-icon-view {
        background: transparent; border: 1px solid #e2e8f0; color: #94a3b8;
        width: 30px; height: 30px; border-radius: 6px; transition: all 0.2s;
    }
    .btn-icon-view:hover { background: #6366f1; color: white; border-color: #6366f1; transform: scale(1.1); }
    
    @keyframes slideInRight {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }
</style>

@code {
    private List<AuditLogDto> _logs = new();
    private GetAuditLogsInput _input = new() { MaxResultCount = 10, Sorting = "ExecutionTime DESC" };
    private long _totalCount;
    private int _currentPage = 1;
    private bool _loading = true;
    private AuditLogDto? _selectedLog;
    private string _activeTab = "actions";

    protected override async Task OnInitializedAsync()
    {
        await LoadLogsAsync();
    }

    private async Task LoadLogsAsync()
    {
        _loading = true;
        try
        {
            var result = await AuditLogService.GetListAsync(_input);
            _logs = result.Items.ToList();
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            ToastService.Error("Fault encountered during trace retrieval: " + ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        _currentPage = 1;
        _input.SkipCount = 0;
        await LoadLogsAsync();
    }

    private async Task RefreshAsync() => await LoadLogsAsync();

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        _input.SkipCount = (page - 1) * _input.MaxResultCount;
        await LoadLogsAsync();
    }

    private async Task ViewDetails(AuditLogDto log)
    {
        _loading = true;
        try 
        {
            _selectedLog = await AuditLogService.GetAsync(log.Id);
            _activeTab = "actions";
        }
        catch (Exception)
        {
            ToastService.Error("Failed to expand audit entry details.");
        }
        finally
        {
            _loading = false;
        }
    }

    private void CloseDetails() => _selectedLog = null;

    private async Task ShowDeleteDialog()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Purge all audit logs older than 30 days? This action cannot be undone."))
        {
            try
            {
                var count = await AuditLogService.DeleteOlderThanAsync(DateTimeOffset.Now.AddDays(-30));
                ToastService.Success($"Audit trail purged. {count} entries removed.");
                await LoadLogsAsync();
            }
            catch (Exception)
            {
                ToastService.Error("Cleanup operation failed.");
            }
        }
    }

    private string GetStatusType(int code) => code switch
    {
        >= 200 and < 300 => "success",
        >= 400 and < 500 => "warning",
        >= 500 => "danger",
        _ => "secondary"
    };

    private string GetDurationType(int ms) => ms switch
    {
        < 300 => "fast",
        < 1500 => "medium",
        _ => "slow"
    };

    private string GetMutationTypeBadge(CEntityChangeType type) => type switch
    {
        CEntityChangeType.Created => "bg-success",
        CEntityChangeType.Updated => "bg-warning text-dark",
        CEntityChangeType.Deleted => "bg-danger",
        _ => "bg-secondary"
    };

    private string ExtractEntityName(string? fullName)
    {
        if (string.IsNullOrEmpty(fullName)) return "Anonymous Entity";
        var parts = fullName.Split('.');
        return parts.Last();
    }
}
