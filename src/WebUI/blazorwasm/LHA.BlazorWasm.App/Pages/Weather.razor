@page "/weather"
@attribute [Route("/weather-forecast")]
@inject HttpClient Http

<PageTitle>Weather Forecast</PageTitle>

<div class="weather-page container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1 fw-bold text-dark">Weather Stations</h1>
            <div class="small text-muted">Daily forecast reports from regional sensor networks.</div>
        </div>
    </div>

    @* Premium DataTable Integration *@
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <DataTable TItem="WeatherForecast" Items="_forecasts" Mode="DataTableMode.ClientSide"
                       TableId="@DataTableIds.Weather"
                       Searchable="true" ShowToolbar="true" ShowPager="true" DefaultPageSize="5">
                
                <ToolbarTemplate>
                    <div class="small text-muted py-2 px-1">Location: Hanoi, VN</div>
                </ToolbarTemplate>

                <ChildContent>
                    <DataTableColumn TItem="WeatherForecast" Title="Station Index" Property="@(x => x.Date)" Sortable Filterable>
                        <CellTemplate>
                            <span class="text-primary fw-bold small">@context.Date.ToString("MM/dd/yyyy")</span>
                        </CellTemplate>
                    </DataTableColumn>

                    <DataTableColumn TItem="WeatherForecast" Title="Station Temperature (C)" Property="@(x => x.TemperatureC)" 
                                   Alignment="ColumnAlignment.Left" Sortable Filterable />

                    <DataTableColumn TItem="WeatherForecast" Title="Station Temperature (F)" Property="@(x => x.TemperatureF)" 
                                   Alignment="ColumnAlignment.Left" Sortable Filterable />

                    <DataTableColumn TItem="WeatherForecast" Title="Environmental Summary" Width="auto" Property="@(x => x.Summary)" 
                                   Sortable Filterable CellStyle='_ => "background: var(--warning-bg, #fffcf0);"'>
                        <CellTemplate>
                            <div class="text-dark fw-bold small">@context.Summary</div>
                        </CellTemplate>
                    </DataTableColumn>

                    <DataTableColumn TItem="WeatherForecast" Title="Actions" Width="80px" Alignment="ColumnAlignment.Right">
                        <CellTemplate>
                            <button class="btn btn-sm btn-icon-replica">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            </button>
                        </CellTemplate>
                    </DataTableColumn>
                </ChildContent>
            </DataTable>
        </div>
    </div>
</div>

<style>
    .btn-icon-replica {
        width: 30px; height: 30px; padding: 0; display: inline-flex; align-items: center; justify-content: center;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 6px; color: #64748b; transition: all 0.2s;
    }
    .btn-icon-replica:hover { background: #f8fafc; color: #4f46e5; border-color: #cbd5e1; }
</style>

@code {
    private List<WeatherForecast> _forecasts = new();

    protected override async Task OnInitializedAsync()
    {
        // Sample data to match the high-end table screenshot
        _forecasts = new List<WeatherForecast>
        {
            new() { Date = new DateTime(2022, 1, 6), TemperatureC = 1, Summary = "Freezing" },
            new() { Date = new DateTime(2022, 1, 7), TemperatureC = 14, Summary = "Bracing" },
            new() { Date = new DateTime(2022, 1, 8), TemperatureC = -13, Summary = "Freezing" },
            new() { Date = new DateTime(2022, 1, 9), TemperatureC = -16, Summary = "Balmy" },
            new() { Date = new DateTime(2022, 1, 10), TemperatureC = -2, Summary = "Chilly" },
            new() { Date = new DateTime(2022, 1, 11), TemperatureC = 25, Summary = "Warm" },
            new() { Date = new DateTime(2022, 1, 12), TemperatureC = 32, Summary = "Hot" }
        };
    }

    public class WeatherForecast
    {
        public DateTime Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}
