        .ToList();

    private async Task<IEnumerable<SelectOption<string>>> SearchUsersFromApi(string query)
    {
        await Task.Delay(400); // Faster mock search
        if (string.IsNullOrEmpty(query)) return userOptions;
        
        return userOptions.Where(o => o.Label.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task<(IEnumerable<SelectOption<int>> Items, int TotalCount)> LoadLargeDataAsync(int startIndex, int count,
string? searchText)
    {
        // NO Task.Delay here for maximum performance test
        // Use pre-generated list to avoid GC pressure
        var query = largeOptions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            query = query.Where(o => o.Label.Contains(searchText, StringComparison.OrdinalIgnoreCase));
        }

        var total = query.Count();
        var items = query.Skip(startIndex).Take(count).ToList();

        return (items, total);
    }

