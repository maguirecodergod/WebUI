@page "/"
@implements IDisposable
@using LHA.BlazorWasm.Components.Select
@using LHA.BlazorWasm.Components.Breadcrumb
@using LHA.BlazorWasm.Components.Section
@using LHA.BlazorWasm.Components.Switch
@using LHA.BlazorWasm.Components.Tooltip
@using System.ComponentModel.DataAnnotations

<PageTitle>@L.L("Common.Save")</PageTitle>

@* <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>@L.L("User.Title")</h1>
    
    <div style="display: flex; gap: 1rem; align-items: center;">
        <LanguageSelector Mode="CLanguageSelectorMode.Dropdown"
                          SupportedLanguages="new[] { CLanguageCode.EN, CLanguageCode.VI, CLanguageCode.FR, CLanguageCode.ES, CLanguageCode.JA }" />
    </div>
</div> *@

<p>@L.L("User.Create") | @L.L("Common.Cancel") | @L.L("Common.Delete")</p>

<hr />
<h2>Breadcrumb Examples</h2>

<div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2rem; margin-top: 1rem;">
    <div>
        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Markup Mode (Default)</h3>
        <Breadcrumb>
            <BreadcrumbItem Text="Home" Href="/" Icon="fas fa-home" />
            <BreadcrumbItem Text="UI Components" Href="/components" />
            <BreadcrumbItem Text="Breadcrumb" />
        </Breadcrumb>
    </div>

    <div>
        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Data-Driven Mode & Custom Separator</h3>
        <Breadcrumb Items="breadcrumbDataItems" Separator=">" />
    </div>
</div>

<hr />
<h2>Button Examples</h2>

<Button Style="CButtonStyle.Secondary" Icon="fas fa-arrow-right" IconPosition="CButtonIconPosition.Right">
    Secondary w/ Icon
</Button>

<Button Style="CButtonStyle.Success" IsLoading="@isLoading" OnClick="SimulateLoadAsync">
    Save Changes (Async)
</Button>

<Button Style="CButtonStyle.Danger" Disabled="true">
    Disabled Button
</Button>

<Button Style="CButtonStyle.Link" FullWidth="true" OnClick="OnLinkClick">
    Full Width Link
</Button>

<hr />
<h2>Toast Notification Examples</h2>

<div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 2rem; margin-top: 1rem; flex-wrap: wrap;">
    <Button Style="CButtonStyle.Success"
            OnClick="@(() => ToastService.Success("<b>All changes</b> have been saved <br/> successfully to the server.", "Success"))">
        Show Success
    </Button>
    <Button Style="CButtonStyle.Primary"
            OnClick="@(() => ToastService.Info("A new system update is available for download a sdoiya oidy aoi dysoai ydosiay doisaydo isay oidsya oidyaoidysoaiyd oisay doiay doisay doiasy odisayodi yaoid yaoiy doisaydoisay doisaydoiyas oidysaoi ydsoiay doisay doiay odisy aoidysoai ydoisay doisay odiysaoi dysaoi dyaoi dyasoiy doisay doisay odisay oidyaoi dysoai ydosia ydoasiy doasiy dosiay doiasy oisay doisay oisayo diyaoid ysoaiy odisay.", "Update Available"))">
        Show Info
    </Button>
    <Button Style="CButtonStyle.Secondary"
            OnClick="@(() => ToastService.Warning("Your storage is almost full (92% used).", "Storage Warning"))">
        Show Warning
    </Button>
    <Button Style="CButtonStyle.Danger"
            OnClick="@(() => ToastService.Error("Unexpected disconnection while fetching data.", "Connection Error"))">
        Show Error
    </Button>
    <Button Style="CButtonStyle.Secondary"
            OnClick="@(() => ToastService.Show("This notification will stay for 10 seconds.", CToastLevel.Info, "Persistent Info", 10000))">
        Show Custom (10s)
    </Button>
</div>

<hr />
<h2>Date & Time Picker Examples</h2>

<div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2rem; margin-top: 1rem;">
    <!-- Single Date Pickers -->
    <div style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
        <div>
            <label
                style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Date
                Picker</label>
                <DatePicker TValue="DateTime?" @bind-Value="testDate" Placeholder="Select Date" />
            </div>
        
            <div>
                <label
                    style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Time
                    Picker (12h)</label>
                    <TimePicker TValue="DateTime?" @bind-Value="testTime" Placeholder="Select Time" />
                </div>
        
                <div>
                    <label
                        style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Date
                        Time Picker (24h)</label>
                        <DateTimePicker TValue="DateTime?" @bind-Value="testDateTime" Is24Hour="true"
                                        Placeholder="Select Date and Time" />
                    </div>
                </div>
    
                <!-- Range Pickers -->
                <div style="display: flex; gap: 2rem; align-items: flex-end; flex-wrap: wrap;">
                    <div>
                        <label
                            style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Date
                            Range</label>
                            <DateRangePicker TInner="DateTime?" @bind-Value="testDateRange" Placeholder="Select Range" />
                        </div>
        
                        <div>
                            <label
                                style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Time
                                Range</label>
                                <TimeRangePicker TInner="DateTime?" @bind-Value="testTimeRange" Placeholder="Start ~ End" />
                            </div>
        
                            <div style="width: 100%;">
                                <label
                                    style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Date
                                    Time Range (Massive)</label>
                                    <DateTimeRangePicker TInner="DateTime?" @bind-Value="testDateTimeRange" Placeholder="Select Bounds" />
                                </div>
                            </div>
    
                            <!-- Validation Examples -->
                            <div
                                style="background: var(--hover-bg); padding: 1.5rem; border-radius: 12px; margin-top: 1rem; border: 1px solid var(--border-color);">
                                <h3 style="margin-top: 0; font-size: 1.2rem; font-weight: 700;">Validation States</h3>
                                <div style="display: flex; gap: 2rem; align-items: flex-end; flex-wrap: wrap;">
                                    <div>
                                        <label
                                            style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Error
                                            State</label>
                                            <DatePicker TValue="DateTime?" CValidationStatus="CValidationStatus.Error"
                                                        ValidationMessage="@L.L("Validation.DateInPast")" />
                                        </div>
                                        <div>
                                            <label
                                                style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Warning
                                                State</label>
                                                <TimePicker TValue="DateTime?" CValidationStatus="CValidationStatus.Warning"
                                                            ValidationMessage="@L.L("Validation.LimitedAvailability")" />
                                            </div>
                                            <div>
                                                <label
                                                    style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Success
                                                    State</label>
                                                    <DateTimePicker TValue="DateTime?" CValidationStatus="CValidationStatus.Success"
                                                                    ValidationMessage="@L.L("Validation.LooksGood")" />
                                                </div>
                                                <div style="width: 100%;">
                                                    <label
                                                        style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Range
                                                        Error</label>
                                                        <DateRangePicker TInner="DateTime?" CValidationStatus="CValidationStatus.Error"
                                                                         ValidationMessage="@L.L("Validation.OverlapBooking")" />
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- DateTimeOffset Examples (New) -->
                                            <div
                                                style="background: var(--hover-bg); padding: 1.5rem; border-radius: 12px; margin-top: 1rem; border: 1px solid var(--border-color);">
                                                <h3 style="margin-top: 0; font-size: 1.2rem; font-weight: 700;">Enterprise Support: DateTimeOffset</h3>
                                                <div style="display: flex; gap: 2rem; align-items: flex-end; flex-wrap: wrap;">
                                                    <div>
                                                        <label
                                                            style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">DTO
                                                            Date Picker</label>
                                                            <DatePicker TValue="DateTimeOffset?" @bind-Value="testDtoDate" Placeholder="" />
                                                            <div style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--primary-color);">Value:
                                                                @testDtoDate?.ToString("O")</div>
                                                            </div>
                                                            <div>
                                                                <label
                                                                    style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">DTO
                                                                    DateTime Picker</label>
                                                                    <DateTimePicker TValue="DateTimeOffset?" @bind-Value="testDtoDateTime" Is24Hour="true" />
                                                                    <div style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--primary-color);">Value:
                                                                        @testDtoDateTime?.ToString("O")</div>
                                                                    </div>
                                                                    <div style="width: 100%;">
                                                                        <label
                                                                            style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">DTO
                                                                            Date Range Picker</label>
                                                                            <DateRangePicker TInner="DateTimeOffset?" @bind-Value="testDtoRange" />
                                                                            <div style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--primary-color);">Range:
                                                                                @testDtoRange.Start?.ToString("d") ~ @testDtoRange.End?.ToString("d")</div>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Disabled Date Logic Example (New) -->
                                                                    <div
                                                                        style="background: var(--hover-bg); padding: 1.5rem; border-radius: 12px; margin-top: 1rem; border: 1px solid var(--border-color);">
                                                                        <h3 style="margin-top: 0; font-size: 1.2rem; font-weight: 700;">Custom Disabled Dates (No Weekends)</h3>
                                                                        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
                                                                            Example: Disabling all Saturdays and Sundays using <code>DisabledDateFunc</code>.
                                                                        </p>
                                                                        <div style="display: flex; gap: 2rem; align-items: flex-end; flex-wrap: wrap;">
                                                                            <div>
                                                                                <label
                                                                                    style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Disabled
                                                                                    Weekends</label>
                                                                                    <DatePicker TValue="DateTime?" DisabledDateFunc="DisableWeekends"
                                                                                                Placeholder="Try picking a weekend..." />
                                                                                </div>
                                                                                <div>
                                                                                    <label
                                                                                        style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Range
                                                                                        with Disabled Weekends</label>
                                                                                        <DateRangePicker TInner="DateTime?" DisabledDateFunc="DisableWeekends" Placeholder="Start ~ End" />
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>

                                                                        <hr />
                                                                        <h2>Tooltip Component Examples</h2>

                                                                        <div style="display: flex; gap: 2rem; align-items: center; margin-bottom: 2rem; margin-top: 1rem;">
                                                                            <Tooltip Text="Top tooltip" Placement="CTooltipPlacement.Top">
                                                                                <Button>Top Placement</Button>
                                                                            </Tooltip>

                                                                            <Tooltip Text="Bottom tooltip" Placement="CTooltipPlacement.Bottom">
                                                                                <Button>Bottom Placement</Button>
                                                                            </Tooltip>

                                                                            <Tooltip Text="Left tooltip" Placement="CTooltipPlacement.Left">
                                                                                <Button>Left Placement</Button>
                                                                            </Tooltip>

                                                                            <Tooltip Text="Right tooltip" Placement="CTooltipPlacement.Right">
                                                                                <Button>Right Placement</Button>
                                                                            </Tooltip>
                                                                        </div>

                                                                        <div style="display: flex; gap: 2rem; align-items: center; margin-bottom: 4rem;">
                                                                            <Tooltip Text="Requires a click" Trigger="CTooltipTrigger.Click">
                                                                                <Button Style="CButtonStyle.Primary">Click me</Button>
                                                                            </Tooltip>

                                                                            <Tooltip Text="Appears on focus" Trigger="CTooltipTrigger.Focus">
                                                                                <input type="text" placeholder="Focus me" class="form-control" style="width: 200px;" />
                                                                            </Tooltip>

                                                                            <Tooltip Placement="CTooltipPlacement.Right">
                                                                                <TooltipContent>
                                                                                    <strong>Advanced Content!</strong><br />
                                                                                    With <em>HTML</em> support.
                                                                                </TooltipContent>
                                                                                <ChildContent>
                                                                                    <span
                                                                                    style="font-size: 0.9rem; cursor:help; background:#0d6efd; color:#fff; border-radius:50%; width:24px; height:24px; display:inline-flex; align-items:center; justify-content:center; font-weight:bold;">?</span>
                                                                                </ChildContent>
                                                                            </Tooltip>
                                                                        </div>

                                                                        <hr />
                                                                        <h2>Skeleton Component Examples</h2>

                                                                        <div style="display: flex; flex-direction: column; gap: 2rem; max-width: 600px; margin-top: 2rem; margin-bottom: 4rem;">
                                                                            <div>
                                                                                <h3>Basic & Text Variants (Wave Animation)</h3>
                                                                                <Skeleton Width="30%" Height="1.5rem" Style="margin-bottom: 1rem;" /> <!-- Title placeholder -->
                                                                                <Skeleton Variant="CSkeletonVariant.Text" Count="4" /> <!-- Paragraph placeholder -->
                                                                            </div>

                                                                            <div>
                                                                                <h3>Avatar & Card Combo (Pulse Animation)</h3>
                                                                                <div style="display: flex; gap: 1rem; align-items: flex-start;">
                                                                                    <Skeleton Variant="CSkeletonVariant.Circular" Width="60px" Height="60px"
                                                                                              Animation="CSkeletonAnimation.Pulse" />
                                                                                    <div style="flex: 1;">
                                                                                        <Skeleton Variant="CSkeletonVariant.Rectangular" Height="150px" Animation="CSkeletonAnimation.Pulse" />
                                                                                    </div>
                                                                                </div>
                                                                            </div>

                                                                            <div>
                                                                                <h3>Wrapper / IsLoading Toggle</h3>
                                                                                <div style="border: 1px solid #ddd; padding: 1rem; border-radius: 8px;">
                                                                                    <Skeleton IsLoading="@isLoadingData">
                                                                                        <div style="display: flex; align-items: center; gap: 1rem;">
                                                                                            <div
                                                                                                style="width: 50px; height: 50px; border-radius: 50%; background: #0d6efd; color: white; display:flex; align-items:center; justify-content:center; font-weight:bold;">
                                                                                                JD
                                                                                            </div>
                                                                                            <div>
                                                                                                <h4 style="margin: 0;">John Doe</h4>
                                                                                                <p style="margin: 0; color: #666;">Software Architect</p>
                                                                                            </div>
                                                                                        </div>
                                                                                    </Skeleton>
            
                                                                                    <div style="margin-top: 1rem;">
                                                                                        <Button Style="CButtonStyle.Primary" Size="CButtonSize.Small" OnClick="ToggleDataLoadingAsync">
                                                                                            Toggle Loading State
                                                                                        </Button>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>

                                                                        <hr />
                                                                        <h2>Status Badge Examples</h2>

                                                                        <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 4rem; margin-top: 1rem;">
                                                                            <div>
                                                                                <h3>Order Statuses</h3>
                                                                                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                                                                    <StatusBadge Status="COrderStatus.Pending" />
                                                                                    <StatusBadge Status="COrderStatus.Processing" />
                                                                                    <StatusBadge Status="COrderStatus.Completed" />
                                                                                    <StatusBadge Status="COrderStatus.Cancelled" />
                                                                                </div>
                                                                            </div>

                                                                            <div>
                                                                                <h3>Payment Statuses (Soft Variant - Matching requested style)</h3>
                                                                                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                                                                    <StatusBadge Status="CPaymentStatus.Unpaid" />
                                                                                    <StatusBadge Status="CPaymentStatus.Paid" />
                                                                                    <StatusBadge Status="CPaymentStatus.Failed" />
                                                                                    <StatusBadge Status="CPaymentStatus.Refunded" />
                                                                                </div>
                                                                            </div>

                                                                            <div>
                                                                                <h3>Variant Comparison</h3>
                                                                                <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                                                                                    <span>Solid:
                                                                                        <StatusBadge Status="COrderStatus.Completed" />
                                                                                    </span>
                                                                                    <span>Soft:
                                                                                        <StatusBadge Status="CPaymentStatus.Paid" />
                                                                                    </span>
                                                                                </div>
                                                                            </div>

                                                                            <div>
                                                                                <h3>Custom Overrides</h3>
                                                                                <div style="display: flex; gap: 0.5rem; align-items: center;">
                                                                                    <StatusBadge Status="COrderStatus.Completed">
                                                                                        <i class="fas fa-star me-1"></i> Special Order
                                                                                    </StatusBadge>
            
                                                                                    <StatusBadge Status="CPaymentStatus.Paid" Class="p-3 shadow-sm rounded-pill" />
                                                                                </div>
                                                                            </div>
                                                                        </div>

                                                                        <hr />
                                                                        <h2>Select Component Examples</h2>

                                                                        <div style="display: flex; flex-direction: column; gap: 2rem; margin-top: 1rem; margin-bottom: 4rem;">
                                                                            <!-- Basic Selection -->
                                                                            <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                                                                                <div style="flex: 1; min-width: 300px;">
                                                                                    <label
                                                                                        style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Standard
                                                                                        Select</label>
                                                                                        <Select TValue="string" Options="cityOptions" @bind-Value="selectedCity" Placeholder="Choose a city..." />
                                                                                        <div style="margin-top: 0.5rem; font-size: 0.85rem;">Selected: <b>@selectedCity</b></div>
                                                                                    </div>

                                                                                    <div style="flex: 1; min-width: 300px;">
                                                                                        <label
                                                                                            style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Searchable
                                                                                            Select</label>
                                                                                            <Select TValue="string" Options="cityOptions" Searchable="true" @bind-Value="selectedSearchCity"
                                                                                                    Placeholder="Search cities..." />
                                                                                        </div>
                                                                                    </div>

                                                                                    <!-- Multi Select & Templates -->
                                                                                    <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                                                                                        <div style="flex: 1; min-width: 300px;">
                                                                                            <label
                                                                                                style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Multi
                                                                                                Select (Tags)</label>
                                                                                                <Select TValue="string" Options="tagOptions" Mode="CSelectMode.Multiple" @bind-Values="selectedTags"
                                                                                                        Placeholder="Select tags..." />
                                                                                            </div>

                                                                                            <div style="flex: 1; min-width: 300px;">
                                                                                                <label
                                                                                                    style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Custom
                                                                                                    Templates</label>
                                                                                                    <Select TValue="string" Options="userOptions" @bind-Value="selectedUser">
                                                                                                        <OptionTemplate Context="opt">
                                                                                                            <div style="display: flex; align-items: center; gap: 8px;">
                                                                                                                <div
                                                                                                                    style="width: 20px; height: 20px; border-radius: 50%; background: #0d6efd; color: white; display: flex; align-items: center; justify-content: center; font-size: 0.7rem;">
                                                                                                                    @opt.Label[0]</div>
                                                                                                                    <span>@opt.Label</span>
                                                                                                                </div>
                                                                                                            </OptionTemplate>
                                                                                                        </Select>
                                                                                                    </div>
                                                                                                </div>

                                                                                                <!-- Virtualization & Async -->
                                                                                                <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                                                                                                    <div style="flex: 1; min-width: 300px;">
                                                                                                        <label
                                                                                                            style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Virtualization
                                                                                                            Test (10,000 items)</label>
                                                                                                            <Select TValue="int" Searchable="true" OnLoadPage="LoadLargeDataAsync"
                                                                                                                    Placeholder="Scroll fast - no lag!" />
                                                                                                        </div>

                                                                                                        <div style="flex: 1; min-width: 300px;">
                                                                                                            <label
                                                                                                                style="display:block; font-weight:bold; margin-bottom:0.5rem; font-size: 0.9rem; color: var(--text-muted);">Async
                                                                                                                API Search</label>
                                                                                                                <Select TValue="string" AsyncSearch="true" LoadOptions="SearchUsersFromApi"
                                                                                                                        Placeholder="Type to fetch users..." />
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>

                                                                                                    <hr />
                                                                                                    <h2>@L.L("FormField.DemoTitle")</h2>

                                                                                                    <div style="display: flex; flex-direction: column; gap: 2rem; margin-top: 1rem; margin-bottom: 4rem;">
                                                                                                        @* ── Vertical Layout with EditForm Validation ── *@
                                                                                                        <div
                                                                                                            style="background: var(--hover-bg); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color);">
                                                                                                            <h3 style="margin-top: 0; font-size: 1.2rem; font-weight: 700;">Vertical Layout (Default)</h3>
                                                                                                            <EditForm Model="@_demoModel" OnValidSubmit="HandleValidSubmit" style="max-width: 480px;">
                                                                                                                <DataAnnotationsValidator />

                                                                                                                <FormField Label="@L.L("FormField.DemoName")" Required="true" Help="@L.L("FormField.DemoNameHelp")"
                                                                                                                           ValueExpression="@(() => (object)_demoModel.FullName!)">
                                                                                                                    <InputText @bind-Value="_demoModel.FullName" class="form-control" placeholder="John Doe" />
                                                                                                                </FormField>

                                                                                                                <FormField Label="@L.L("FormField.DemoEmail")" Required="true" Help="@L.L("FormField.DemoEmailHelp")"
                                                                                                                           ValueExpression="@(() => (object)_demoModel.Email!)">
                                                                                                                    <InputText @bind-Value="_demoModel.Email" class="form-control" placeholder="you@example.com" />
                                                                                                                </FormField>

                                                                                                                <div style="display: flex; gap: 0.75rem; margin-top: 0.5rem;">
                                                                                                                    <Button Type="CButtonType.Submit" Style="CButtonStyle.Primary">
                                                                                                                        @L.L("FormField.DemoSubmit")
                                                                                                                    </Button>
                                                                                                                    <Button Style="CButtonStyle.Secondary" OnClick="ResetForm">
                                                                                                                        @L.L("FormField.DemoReset")
                                                                                                                    </Button>
                                                                                                                </div>
                                                                                                            </EditForm>

                                                                                                            @if (_formSubmitted)
                                                                                                            {
                                                                                                                <div
                                                                                                                    style="margin-top: 1rem; padding: 0.75rem 1rem; background: rgba(25,135,84,0.1); border: 1px solid var(--success-color, #198754); border-radius: 0.5rem; color: var(--success-color, #198754); font-size: 0.9rem;">
                                                                                                                    ✓ Form submitted: <strong>@_demoModel.FullName</strong> — @_demoModel.Email
                                                                                                                </div>
                                                                                                            }
                                                                                                        </div>

                                                                                                        @* ── Horizontal Layout ── *@
                                                                                                        <div
                                                                                                            style="background: var(--hover-bg); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color);">
                                                                                                            <h3 style="margin-top: 0; font-size: 1.2rem; font-weight: 700;">Horizontal Layout</h3>
                                                                                                            <div style="max-width: 600px;">
                                                                                                                <FormField Label="@L.L("FormField.DemoCountry")" Layout="CFormFieldLayout.Horizontal">
                                                                                                                    <Select TValue="string" Options="countryOptions" @bind-Value="selectedCountry"
                                                                                                                            Placeholder="Choose a country..." />
                                                                                                                </FormField>

                                                                                                                <FormField Label="@L.L("FormField.DemoEmail")" Layout="CFormFieldLayout.Horizontal"
                                                                                                                           Help="@L.L("FormField.DemoEmailHelp")">
                                                                                                                    <InputText @bind-Value="_demoModel.Email" class="form-control" placeholder="you@example.com" />
                                                                                                                </FormField>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>

                                                                                                    <hr />
                                                                                                    <h2>@L.L("Section.DemoTitle")</h2>

                                                                                                    <div
                                                                                                        style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1rem; margin-bottom: 4rem; max-width: 700px;">
                                                                                                        @* ── Collapsible Section with FormFields ── *@
                                                                                                        <Section Title="@L.L("Section.UserInfo")" Collapsible="true" DefaultExpanded="true">
                                                                                                            <FormField Label="@L.L("FormField.DemoName")" Required="true" Help="@L.L("FormField.DemoNameHelp")">
                                                                                                                <InputText @bind-Value="_demoModel.FullName" class="form-control" placeholder="John Doe" />
                                                                                                            </FormField>
                                                                                                            <FormField Label="@L.L("FormField.DemoEmail")" Help="@L.L("FormField.DemoEmailHelp")">
                                                                                                                <InputText @bind-Value="_demoModel.Email" class="form-control" placeholder="you@example.com" />
                                                                                                            </FormField>
                                                                                                        </Section>

                                                                                                        @* ── Section with Icon (starts collapsed) ── *@
                                                                                                        <Section Title="@L.L("Section.Security")" Icon="🔒" Collapsible="true" DefaultExpanded="false">
                                                                                                            <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
                                                                                                                @L.L("Section.SecurityNote")
                                                                                                            </p>
                                                                                                        </Section>

                                                                                                        @* ── Subtle Variant ── *@
                                                                                                        <Section Title="@L.L("Section.Notifications")" Icon="🔔" Collapsible="true" Variant="CSectionVariant.Subtle">
                                                                                                            <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
                                                                                                                @L.L("Section.NotificationNote")
                                                                                                            </p>
                                                                                                        </Section>

                                        @* ── Non-collapsible (always open) ── *@
                                        <Section Title="Static Content">
                                            <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
                                                This section is always visible. It cannot be collapsed because <code>Collapsible</code> is not set.
                                            </p>
                                        </Section>
                                    </div>

                                    <hr />
                                    <h2>Switch Component Examples</h2>

                                    <div style="display: flex; flex-direction: column; gap: 2rem; margin-top: 1rem; margin-bottom: 4rem;">
                                        @* Basic Switch *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Basic Switch</h3>
                                                <Switch @bind-Value="switchValue1" Label="Enable notifications" />
                                                <div style="margin-top: 0.5rem; font-size: 0.85rem;">Value: <b>@switchValue1</b></div>
                                            </div>
                                        </div>

                                        @* Switch Sizes *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: flex-end;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Small</h3>
                                                <Switch @bind-Value="switchValue2" Size="CSwitchSize.Small" Label="Small switch" />
                                            </div>
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Medium</h3>
                                                <Switch @bind-Value="switchValue3" Size="CSwitchSize.Medium" Label="Medium switch" />
                                            </div>
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Large</h3>
                                                <Switch @bind-Value="switchValue4" Size="CSwitchSize.Large" Label="Large switch" />
                                            </div>
                                        </div>

                                        @* Switch with Icons *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">With Icons (Check/X)</h3>
                                                <Switch @bind-Value="switchValue5" ShowIcons="true" OffIcon="fas fa-times" OnIcon="fas fa-check" />
                                            </div>
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">With Icons (Sun/Moon)</h3>
                                                <Switch @bind-Value="switchValue6" ShowIcons="true" OffIcon="fas fa-moon" OnIcon="fas fa-sun" />
                                            </div>
                                        </div>

                                        @* Switch with Tooltip *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">With Tooltip</h3>
                                                <Switch @bind-Value="switchValue7" Tooltip="Toggle feature on/off" Label="Feature toggle" />
                                            </div>
                                        </div>

                                        @* Switch with Label Position *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Left Label</h3>
                                                <Switch @bind-Value="switchValue8" Label="Left label" LabelPosition="CSwitchLabelPosition.Left" />
                                            </div>
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Right Label</h3>
                                                <Switch @bind-Value="switchValue9" Label="Right label" LabelPosition="CSwitchLabelPosition.Right" />
                                            </div>
                                        </div>

                                        @* Disabled Switch *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Disabled (Off)</h3>
                                                <Switch Disabled="true" Value="false" Label="Disabled off" />
                                            </div>
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Disabled (On)</h3>
                                                <Switch Disabled="true" Value="true" Label="Disabled on" />
                                            </div>
                                        </div>

                                        @* Combined: Icons + Tooltip *@
                                        <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                                            <div>
                                                <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Combined: Icons + Tooltip</h3>
                                                <Switch @bind-Value="switchValue10" 
                                                        ShowIcons="true" 
                                                        OffIcon="fas fa-moon" 
                                                        OnIcon="fas fa-sun" 
                                                        Tooltip="Toggle dark mode"
                                                        Size="CSwitchSize.Large" />
                                            </div>
                                        </div>
                                    </div>

@code {

