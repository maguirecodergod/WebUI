@page "/test"
@using System.Text.Json
@using LHA.Ddd.Application

<PageTitle>API Client Test</PageTitle>

<div class="test-container p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">HTTP API Client SDK Test</h1>
            <p class="text-muted small">Verification suite for the <code>LHA.BlazorWasm.HttpApi.Client</code> library.
            </p>
            <button class="btn btn-dark rounded-3 px-4" @onclick="() => _showUserPicker = true">
                <i class="bi bi-people-fill me-2 text-primary"></i> Show User Picker Demo
            </button>
        </div>
        <div>
            <LHAButton Style="CButtonStyle.Secondary" OnClick="ClearLogs">Clear Logs</LHAButton>
            <LHAButton Style="CButtonStyle.Primary" OnClick="TestAll" Disabled="@_isBusy">Run All Tests</LHAButton>
        </div>
    </div>

    @if (_isBusy)
    {
        <div class="progress my-4 rounded-pill" style="height: 6px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar"
                 style="width: 100%"></div>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
        <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-dark mb-0">Execution Results Log</h5>
        </div>
        <div class="card-body p-0">
            <DataTable TItem="TestResult" Items="_testResults" Searchable="true" TableId="@DataTableIds.TestResults"
                       Hoverable="true" Striped="false" CssClass="border-0 shadow-none">
                <ChildContent>
                    <DataTableColumn TItem="TestResult" Title="Action" Property="@(x => x.Action)" Sortable
                                     Width="250px" />
                    <DataTableColumn TItem="TestResult" Title="Status" Width="120px" Alignment="ColumnAlignment.Center">
                        <CellTemplate>
                            <span class='badge rounded-pill @(context.Success ? "bg-success" : "bg-danger") px-3'>
                                @(context.Success ? "PASSED" : "FAILED")
                            </span>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TItem="TestResult" Title="HTTP Code" Width="150px">
                        <CellTemplate>
                            @if (context.StatusCode != null)
                            {
                                <span class="badge bg-light text-dark border">@((int)context.StatusCode)
                                    (@context.StatusCode)</span>
                                }
                            else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </CellTemplate>
                        </DataTableColumn>
                        <DataTableColumn TItem="TestResult" Title="Timestamp" Width="120px">
                            <CellTemplate>
                                <span class="text-muted small">@context.Timestamp.ToString("HH:mm:ss.fff")</span>
                            </CellTemplate>
                        </DataTableColumn>
                    </ChildContent>

                    <ExpandedRowTemplate>
                        <div class="p-3 bg-light rounded-3 m-2 border">
                            <label class="small fw-bold text-muted mb-2 d-block text-uppercase">Raw Payload /
                                StackTrace</label>
                                <pre class="m-0 p-3 bg-dark text-light rounded small"
                                     style="max-height: 400px; overflow: auto; font-family: 'JetBrains Mono', monospace;">@context.Content</pre>
                            </div>
                        </ExpandedRowTemplate>

                        <EmptyTemplate>
                            <div class="p-5 text-center text-muted">
                                <i class="bi bi-terminal fs-1 d-block mb-3 opacity-25"></i>
                                Ready to start testing. Choose an operation above.
                            </div>
                        </EmptyTemplate>
                    </DataTable>
                </div>
            </div>

            @if (_showUserPicker)
            {
                <LHA.BlazorWasm.Components.Identity.UserPicker OnClose="() => _showUserPicker = false" />
            }
        </div>

        <style>
            .test-container {
                max-width: 1400px;
                margin: 0 auto;
                font-family: 'Outfit', sans-serif;
            }

            .btn-soft-danger {
                background: #fee2e2;
                color: #ef4444;
                border: none;
                transition: all 0.2s;
            }

            .btn-soft-danger:hover {
                background: #ef4444;
                color: white;
                transform: translateY(-3px);
            }

            .btn-soft-primary {
                background: #e0e7ff;
                color: #6366f1;
                border: none;
                transition: all 0.2s;
            }

            .btn-soft-primary:hover {
                background: #6366f1;
                color: white;
                transform: translateY(-3px);
            }

            .btn-soft-secondary {
                background: #f1f5f9;
                color: #64748b;
                border: none;
                transition: all 0.2s;
            }

            .btn-soft-secondary:hover {
                background: #64748b;
                color: white;
                transform: translateY(-3px);
            }

            pre {
                white-space: pre-wrap;
                word-break: break-all;
            }
        </style>

@code {
    private bool _isBusy;
    private bool _showUserPicker;
    private List<TestResult> _testResults = new();

    private async Task TestAll()
    {
        _isBusy = true;
        _testResults.Clear();

        _isBusy = false;
    }

    private async Task ExecuteTest<T>(string actionName, Func<Task<ApiResponse<T>>> action)
    {
        _isBusy = true;
        try
        {
            var response = await action();

            bool isSuccess = response.Result?.Success ?? false;

            string content;
            if (response.Result != null && response.Result.Data is not null)
            {
                content = JsonSerializer.Serialize(response.Result.Data, new JsonSerializerOptions { WriteIndented = true });
            }
            else if (response.Result?.Errors?.Count > 0)
            {
                var firstError = response.Result.Errors[0];
                content = $"Error Message: {firstError.Message}\nDetails: {JsonSerializer.Serialize(response.Result.Errors, new
JsonSerializerOptions
                { WriteIndented = true })}";
            }
            else
            {
                content = "Response contains no data and no error object.";
            }

            _testResults.Insert(0, new TestResult
            {
                Action = actionName,
                Success = isSuccess,
                StatusCode = (System.Net.HttpStatusCode)response.StatusCode,
                Content = content,
                Timestamp = DateTime.Now
            });
        }
        catch (Exception ex)
        {
            _testResults.Insert(0, new TestResult
            {
                Action = actionName,
                Success = false,
                Content = $"Exception: {ex.Message}\n\nStackTrace:\n{ex.StackTrace}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    private void ClearLogs() => _testResults.Clear();

    public class TestResult
    {
        public string Action { get; set; } = string.Empty;
        public bool Success { get; set; }
        public System.Net.HttpStatusCode? StatusCode { get; set; }
        public string Content { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}
