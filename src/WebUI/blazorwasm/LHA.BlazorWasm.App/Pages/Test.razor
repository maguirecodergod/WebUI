@page "/test"
@using LHA.BlazorWasm.HttpApi.Client.Clients
@using System.Text.Json
@using LHA.Ddd.Application
@inject ExampleApiClient ApiClient

<PageTitle>API Client Test</PageTitle>

<div class="test-container p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">HTTP API Client SDK Test</h1>
            <p class="text-muted small">Verification suite for the <code>LHA.BlazorWasm.HttpApi.Client</code> library.
            </p>
            <button class="btn btn-dark rounded-3 px-4" @onclick="() => _showUserPicker = true">
                <i class="bi bi-people-fill me-2 text-primary"></i> Show User Picker Demo
            </button>
        </div>
        <div>
            <Button Style="CButtonStyle.Secondary" OnClick="ClearLogs">Clear Logs</Button>
            <Button Style="CButtonStyle.Primary" OnClick="TestAll" Disabled="@_isBusy">Run All Tests</Button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                    <h5 class="fw-bold text-dark mb-0">Standard Operations</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary text-start rounded-3" @onclick="TestGetWeather"
                                disabled="@_isBusy">
                            <i class="bi bi-cloud-sun me-2"></i> GET Weather (Collection)
                        </button>
                        <button class="btn btn-outline-primary text-start rounded-3" @onclick="() => TestGetUser(1)"
                                disabled="@_isBusy">
                            <i class="bi bi-person me-2"></i> GET User (Single - ID: 1)
                        </button>
                        <button class="btn btn-outline-success text-start rounded-3" @onclick="TestCreateUser"
                                disabled="@_isBusy">
                            <i class="bi bi-person-plus me-2"></i> POST Create User
                        </button>
                        <button class="btn btn-outline-warning text-start rounded-3" @onclick="TestUpdateUser"
                                disabled="@_isBusy">
                            <i class="bi bi-pencil me-2"></i> PUT Update User
                        </button>
                        <button class="btn btn-outline-danger text-start rounded-3" @onclick="TestDeleteUser"
                                disabled="@_isBusy">
                            <i class="bi bi-trash me-1"></i> DELETE User
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                    <h5 class="fw-bold text-dark mb-0">Error & Edge Cases</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-6">
                            <button class="btn btn-soft-danger w-100 h-100 py-3 rounded-3" @onclick="Test404"
                                    disabled="@_isBusy">
                                <div class="fw-bold fs-5">404</div>
                                <div class="small opacity-75">Not Found</div>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-soft-danger w-100 h-100 py-3 rounded-3" @onclick="Test500"
                                    disabled="@_isBusy">
                                <div class="fw-bold fs-5">500</div>
                                <div class="small opacity-75">Server Error</div>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-soft-secondary w-100 h-100 py-3 rounded-3" @onclick="Test401"
                                    disabled="@_isBusy">
                                <div class="fw-bold fs-5">401</div>
                                <div class="small opacity-75">Unauthorized</div>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-soft-primary w-100 h-100 py-3 rounded-3" @onclick="TestAll"
                                    disabled="@_isBusy">
                                <div class="fw-bold fs-5">ALL</div>
                                <div class="small opacity-75">Run Suite</div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_isBusy)
    {
        <div class="progress my-4 rounded-pill" style="height: 6px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar"
                 style="width: 100%"></div>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
        <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-dark mb-0">Execution Results Log</h5>
        </div>
        <div class="card-body p-0">
            <DataTable TItem="TestResult" Items="_testResults" Searchable="true" TableId="@DataTableIds.TestResults"
                       Hoverable="true" Striped="false" CssClass="border-0 shadow-none">
                <ChildContent>
                    <DataTableColumn TItem="TestResult" Title="Action" Property="@(x => x.Action)" Sortable
                                     Width="250px" />
                    <DataTableColumn TItem="TestResult" Title="Status" Width="120px" Alignment="ColumnAlignment.Center">
                        <CellTemplate>
                            <span class='badge rounded-pill @(context.Success ? "bg-success" : "bg-danger") px-3'>
                                @(context.Success ? "PASSED" : "FAILED")
                            </span>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TItem="TestResult" Title="HTTP Code" Width="150px">
                        <CellTemplate>
                            @if (context.StatusCode != null)
                            {
                                <span class="badge bg-light text-dark border">@((int)context.StatusCode)
                                    (@context.StatusCode)</span>
                                }
                            else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </CellTemplate>
                        </DataTableColumn>
                        <DataTableColumn TItem="TestResult" Title="Timestamp" Width="120px">
                            <CellTemplate>
                                <span class="text-muted small">@context.Timestamp.ToString("HH:mm:ss.fff")</span>
                            </CellTemplate>
                        </DataTableColumn>
                    </ChildContent>

                    <ExpandedRowTemplate>
                        <div class="p-3 bg-light rounded-3 m-2 border">
                            <label class="small fw-bold text-muted mb-2 d-block text-uppercase">Raw Payload /
                                StackTrace</label>
                                <pre class="m-0 p-3 bg-dark text-light rounded small"
                                     style="max-height: 400px; overflow: auto; font-family: 'JetBrains Mono', monospace;">@context.Content</pre>
                            </div>
                        </ExpandedRowTemplate>

                        <EmptyTemplate>
                            <div class="p-5 text-center text-muted">
                                <i class="bi bi-terminal fs-1 d-block mb-3 opacity-25"></i>
                                Ready to start testing. Choose an operation above.
                            </div>
                        </EmptyTemplate>
                    </DataTable>
                </div>
            </div>

            @if (_showUserPicker)
            {
                <LHA.BlazorWasm.Components.Identity.UserPicker OnClose="() => _showUserPicker = false" />
            }
        </div>

        <style>
            .test-container {
                max-width: 1400px;
                margin: 0 auto;
                font-family: 'Outfit', sans-serif;
            }

            .btn-soft-danger {
                background: #fee2e2;
                color: #ef4444;
                border: none;
                transition: all 0.2s;
            }

            .btn-soft-danger:hover {
                background: #ef4444;
                color: white;
                transform: translateY(-3px);
            }

            .btn-soft-primary {
                background: #e0e7ff;
                color: #6366f1;
                border: none;
                transition: all 0.2s;
            }

            .btn-soft-primary:hover {
                background: #6366f1;
                color: white;
                transform: translateY(-3px);
            }

            .btn-soft-secondary {
                background: #f1f5f9;
                color: #64748b;
                border: none;
                transition: all 0.2s;
            }

            .btn-soft-secondary:hover {
                background: #64748b;
                color: white;
                transform: translateY(-3px);
            }

            pre {
                white-space: pre-wrap;
                word-break: break-all;
            }
        </style>

@code {
    private bool _isBusy;
    private bool _showUserPicker;
    private List<TestResult> _testResults = new();

    private async Task TestGetWeather() => await ExecuteTest("GET Weather", () => ApiClient.GetWeatherAsync());
    private async Task TestGetUser(int id) => await ExecuteTest($"GET User (ID: {id})", () => ApiClient.GetUserAsync(id));
    private async Task TestCreateUser() => await ExecuteTest("POST Create User", () => ApiClient.CreateUserAsync(new
CreateUserRequest("New User", "new@example.com")));
    private async Task TestUpdateUser() => await ExecuteTest("PUT Update User", () => ApiClient.UpdateUserAsync(1, new
UpdateUserRequest("Updated Name")));
    private async Task TestDeleteUser() => await ExecuteTest("DELETE User", () => ApiClient.DeleteUserAsync(1));
    private async Task Test404() => await ExecuteTest("404 Not Found Test", () => ApiClient.Test404NotFoundAsync());
    private async Task Test500() => await ExecuteTest("500 Server Error Test", () => ApiClient.Test500InternalErrorAsync());
    private async Task Test401() => await ExecuteTest("401 Unauthorized Test", () => ApiClient.Test401UnauthorizedAsync());

    private async Task TestAll()
    {
        _isBusy = true;
        _testResults.Clear();

        await TestGetWeather();
        await TestGetUser(1);
        await TestCreateUser();
        await TestUpdateUser();
        await TestDeleteUser();
        await Test404();
        await Test500();
        await Test401();

        _isBusy = false;
    }

    private async Task ExecuteTest<T>(string actionName, Func<Task<ApiResponse<T>>> action)
    {
        _isBusy = true;
        try
        {
            var response = await action();

            bool isSuccess = response.Result?.Success ?? false;

            string content;
            if (response.Result != null && response.Result.Data is not null)
            {
                content = JsonSerializer.Serialize(response.Result.Data, new JsonSerializerOptions { WriteIndented = true });
            }
            else if (response.Result?.Errors?.Count > 0)
            {
                var firstError = response.Result.Errors[0];
                content = $"Error Message: {firstError.Message}\nDetails: {JsonSerializer.Serialize(response.Result.Errors, new
JsonSerializerOptions
                { WriteIndented = true })}";
            }
            else
            {
                content = "Response contains no data and no error object.";
            }

            _testResults.Insert(0, new TestResult
            {
                Action = actionName,
                Success = isSuccess,
                StatusCode = (System.Net.HttpStatusCode)response.StatusCode,
                Content = content,
                Timestamp = DateTime.Now
            });
        }
        catch (Exception ex)
        {
            _testResults.Insert(0, new TestResult
            {
                Action = actionName,
                Success = false,
                Content = $"Exception: {ex.Message}\n\nStackTrace:\n{ex.StackTrace}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    private void ClearLogs() => _testResults.Clear();

    public class TestResult
    {
        public string Action { get; set; } = string.Empty;
        public bool Success { get; set; }
        public System.Net.HttpStatusCode? StatusCode { get; set; }
        public string Content { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}
