@inject INavigationRegistry NavigationRegistry
@inject IPermissionService PermissionService
@inject NavigationManager NavigationManager
@inject UiStateStore UiState
@implements IDisposable

<aside class="ds-sidebar @StateClass">
    <div class="ds-sidebar__header">
        @if (HeaderContent is not null)
        {
            @HeaderContent
        }
        else
        {
            <div class="ds-sidebar__brand">
                <div class="ds-sidebar__logo">
                    <svg viewBox="0 0 64 64" width="24" height="24" fill="none">
                        <defs>
                            <linearGradient id="sb-lg" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="var(--ds-color-primary-500)" />
                                <stop offset="100%" stop-color="var(--ds-color-accent-500)" />
                            </linearGradient>
                        </defs>
                        <rect x="27" y="14" width="10" height="36" rx="3" fill="url(#sb-lg)" />
                        <rect x="27" y="14" width="10" height="36" rx="3" fill="url(#sb-lg)" transform="rotate(60 32 32)" />
                        <rect x="27" y="14" width="10" height="36" rx="3" fill="url(#sb-lg)" transform="rotate(120 32 32)" />
                        <circle cx="32" cy="32" r="5" fill="var(--ds-color-primary)" />
                    </svg>
                </div>
                <span class="ds-sidebar__brand-text">LHA Platform</span>
            </div>
        }
    </div>

    <nav class="ds-sidebar__nav" role="navigation">
        @foreach (var item in _visibleItems)
        {
            @if (item.IsDivider)
            {
                <div class="ds-sidebar__divider"></div>
            }
            else if (!string.IsNullOrEmpty(item.Group))
            {
                <div class="ds-sidebar__group-label">@item.Group</div>
            }
            else
            {
                <AppSidebarItem Item="@item" IsMini="@IsMini" />
            }
        }
    </nav>

    @if (FooterContent is not null)
    {
        <div class="ds-sidebar__footer">
            @FooterContent
        </div>
    }
</aside>

@if (UiState.IsMobileDrawerOpen)
{
    <div class="ds-sidebar__backdrop" @onclick="() => UiState.CloseMobileDrawer()"></div>
}

@code {
    [Parameter] public string Section { get; set; } = "main";
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    private List<MenuItemDefinition> _visibleItems = [];
    private bool IsMini => !UiState.IsSidebarExpanded;

    private string StateClass
    {
        get
        {
            var classes = new List<string>();
            if (IsMini) classes.Add("ds-sidebar--mini");
            if (UiState.IsMobileDrawerOpen) classes.Add("ds-sidebar--mobile-open");
            return string.Join(" ", classes);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        UiState.OnStateChanged += OnStateChanged;
        NavigationRegistry.OnNavigationChanged += OnNavigationChanged;
        await LoadMenuItems();
    }

    private async Task LoadMenuItems()
    {
        var items = NavigationRegistry.GetMenuItems(Section);
        _visibleItems = [];

        foreach (var item in items)
        {
            if (!string.IsNullOrEmpty(item.Permission))
            {
                if (!await PermissionService.HasPermissionAsync(item.Permission))
                    continue;
            }
            _visibleItems.Add(item);
        }
    }

    private async void OnNavigationChanged()
    {
        await LoadMenuItems();
        await InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        UiState.OnStateChanged -= OnStateChanged;
        NavigationRegistry.OnNavigationChanged -= OnNavigationChanged;
    }
}
