@inject UiStateStore UiState
@inject ICommandPaletteService CommandPalette
@inject INotificationService NotificationService
@inject ITenantContext TenantContext
@inject NavigationManager NavigationManager
@implements IDisposable

<header class="ds-topbar">
    <div class="ds-topbar__left">
        <button class="ds-topbar__toggle" @onclick="ToggleSidebar" title="Toggle sidebar">
            <Icon Name="@IconNames.Menu" Size="20" />
        </button>

        @if (ShowBreadcrumb)
        {
            <AppBreadcrumb />
        }
    </div>

    <div class="ds-topbar__right">
        @* Search / Command Palette trigger *@
        <button class="ds-topbar__search" @onclick="OpenCommandPalette" title="Search (Ctrl+K)">
            <Icon Name="@IconNames.Search" Size="16" />
            <span class="ds-topbar__search-text">Search...</span>
            <kbd class="ds-topbar__kbd">⌘K</kbd>
        </button>

        @* Extension slot for custom actions *@
        <ExtensionSlot SlotName="topbar-actions" />

        @* Notification Bell *@
        <div class="ds-topbar__notification" @onclick="ToggleNotifications">
            <Icon Name="@IconNames.Bell" Size="18" />
            @if (_unreadCount > 0)
            {
                <span class="ds-topbar__badge">@(_unreadCount > 99 ? "99+" : _unreadCount.ToString())</span>
            }
        </div>

        @* Tenant Switcher *@
        @if (!TenantContext.IsHost)
        {
            <div class="ds-topbar__tenant">
                <Icon Name="@IconNames.Building" Size="14" />
                <span>@TenantContext.TenantName</span>
            </div>
        }

        @* User Menu *@
        <div class="ds-topbar__user">
            <div class="ds-topbar__avatar">
                <Icon Name="@IconNames.User" Size="16" />
            </div>
        </div>
    </div>
</header>

@code {
    [Parameter] public bool ShowBreadcrumb { get; set; } = true;

    private int _unreadCount;

    protected override void OnInitialized()
    {
        NotificationService.OnNotificationsChanged += UpdateUnreadCount;
        UpdateUnreadCount();
    }

    private void ToggleSidebar()
    {
        UiState.ToggleSidebar();
    }

    private void OpenCommandPalette()
    {
        UiState.OpenCommandPalette();
    }

    private void ToggleNotifications()
    {
        // Toggle notification panel
    }

    private void UpdateUnreadCount()
    {
        _unreadCount = NotificationService.UnreadCount;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NotificationService.OnNotificationsChanged -= UpdateUnreadCount;
    }
}
