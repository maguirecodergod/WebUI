@inject NavigationManager NavigationManager
@inject INavigationRegistry NavigationRegistry

<nav class="ds-breadcrumb" aria-label="Breadcrumb">
    <ol class="ds-breadcrumb__list">
        <li class="ds-breadcrumb__item">
            <a href="/" class="ds-breadcrumb__link">
                <Icon Name="@IconNames.Home" Size="14" />
            </a>
        </li>
        @foreach (var crumb in _crumbs)
        {
            <li class="ds-breadcrumb__separator" aria-hidden="true">
                <Icon Name="@IconNames.ChevronRight" Size="12" />
            </li>
            <li class="ds-breadcrumb__item @(crumb.IsActive ? "ds-breadcrumb__item--active" : "")">
                @if (crumb.IsActive)
                {
                    <span class="ds-breadcrumb__current">@crumb.Title</span>
                }
                else
                {
                    <a href="@crumb.Path" class="ds-breadcrumb__link">@crumb.Title</a>
                }
            </li>
        }
    </ol>
</nav>

@code {
    private record BreadcrumbItem(string Title, string Path, bool IsActive);

    private List<BreadcrumbItem> _crumbs = [];

    protected override void OnParametersSet()
    {
        BuildBreadcrumbs();
    }

    private void BuildBreadcrumbs()
    {
        _crumbs.Clear();
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var segments = uri.Split('/', StringSplitOptions.RemoveEmptyEntries);

        var path = "/";
        for (var i = 0; i < segments.Length; i++)
        {
            path += segments[i] + "/";
            var routeDef = NavigationRegistry.GetRoute(path.TrimEnd('/'));
            var title = routeDef?.BreadcrumbTitle ?? routeDef?.Title ?? FormatSegment(segments[i]);
            var isActive = i == segments.Length - 1;
            _crumbs.Add(new BreadcrumbItem(title, path.TrimEnd('/'), isActive));
        }
    }

    private static string FormatSegment(string segment)
    {
        if (string.IsNullOrEmpty(segment)) return segment;
        return char.ToUpper(segment[0]) + segment[1..].Replace("-", " ");
    }
}
