@inherits LayoutComponentBase
@inject UiStateStore UiState
@implements IDisposable

<div class="ds-layout ds-layout--dashboard @(UiState.IsSidebarExpanded ? "" : "ds-layout--mini")">
    <AppSidebar Section="main" />

    <div class="ds-layout__main">
        <TopBar />

        <main class="ds-layout__content ds-layout__content--dashboard">
            @Body
        </main>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        UiState.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        UiState.OnStateChanged -= OnStateChanged;
    }
}
