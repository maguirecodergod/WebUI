@inherits LayoutComponentBase
@inject UiStateStore UiState
@implements IDisposable

<div class="ds-layout ds-layout--admin @(UiState.IsSidebarExpanded ? "" : "ds-layout--mini")">
    <AppSidebar Section="admin">
        <HeaderContent>
            <div class="ds-sidebar__brand">
                <div class="ds-sidebar__logo">
                    <Icon Name="@IconNames.Shield" Size="22" CssClass="ds-admin-icon" />
                </div>
                <span class="ds-sidebar__brand-text">Admin Panel</span>
            </div>
        </HeaderContent>
    </AppSidebar>

    <div class="ds-layout__main">
        <TopBar />

        <main class="ds-layout__content">
            <div class="ds-layout__container">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        UiState.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        UiState.OnStateChanged -= OnStateChanged;
    }
}
