@implements IDisposable
@inject IPermissionService PermissionService

@if (_isAuthorized)
{
    @ChildContent
}

@code {
    [Parameter] public string Permission { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _isAuthorized;

    protected override async Task OnInitializedAsync()
    {
        await CheckPermission();
        if (PermissionService is PermissionService ps)
        {
            ps.OnPermissionsChanged += OnPermissionsChanged;
        }
    }

    private async void OnPermissionsChanged()
    {
        await CheckPermission();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckPermission()
    {
        _isAuthorized = string.IsNullOrWhiteSpace(Permission) ||
                        await PermissionService.HasPermissionAsync(Permission);
    }

    public void Dispose()
    {
        if (PermissionService is PermissionService ps)
        {
            ps.OnPermissionsChanged -= OnPermissionsChanged;
        }
    }
}
