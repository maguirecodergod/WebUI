@page "/audit-logs"
@namespace LHA.BlazorWasm.Modules.Tenant.AuditLogs.Pages
@inherits LhaComponentBase

<PageTitle>@L("AuditLog.PageTitle")</PageTitle>

<div class="audit-log-page container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1 fw-bold" style="color: var(--dt-text-primary, inherit);">@L("AuditLog.Title")</h1>
            <div class="small" style="color: var(--dt-text-secondary, inherit); opacity: 0.8;">@L("AuditLog.Subtitle")
            </div>
        </div>
        <Button Style="CButtonStyle.Secondary" Size="CButtonSize.Medium" OnClick="RefreshAsync">
            <i class="bi bi-arrow-clockwise me-1"></i> @L("Common.Refresh")
        </Button>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <DataTable TItem="AuditLogDto" Items="_logs" Mode="DataTableMode.ServerSide" TotalCount="(int)_totalCount"
                       ServerDataSource="GetDataTableResponseAsync" DefaultPageSize="10" Searchable="true" ShowToolbar="true"
                       KeySelector="@(x => x.Id)" TableId="@DataTableIds.AuditLogs">

                <ChildContent>
                    <DataTableColumn TItem="AuditLogDto" Title="@L("AuditLog.ExecutionTime")" Width="180px" Sortable
                                     Property="@(x => x.ExecutionTime)">
                        <CellTemplate>
                            <span class="small">@context.ExecutionTime.ToString("yyyy-MM-dd HH:mm")</span>
                        </CellTemplate>
                    </DataTableColumn>

                    <DataTableColumn TItem="AuditLogDto" Title="@L("AuditLog.Url")" Width="auto" Sortable
                                     Property="@(x => x.Url)">
                        <CellTemplate>
                            <div class="fw-medium small">@context.Url</div>
                        </CellTemplate>
                    </DataTableColumn>

                    <DataTableColumn TItem="AuditLogDto" Title="@L("AuditLog.ResourceTrace")" Width="auto">
                        <CellTemplate>
                            <div>
                                <div class="fw-bold small" style="color: var(--dt-text-primary);">@(context.ServiceName
                                                                                                                ?? "N/A")</div>
                                    <div class="small" style="color: var(--dt-text-secondary);">@(context.MethodName ??
                                                                                                                         context.ActionName ?? "N/A")</div>
                                    </div>
                                </CellTemplate>
                            </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="@L("AuditLog.User")" Width="150px" Sortable
                                             Property="@(x => x.UserName)">
                                <CellTemplate>
                                    <span class="small">@context.UserName</span>
                                </CellTemplate>
                             </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="@L("AuditLog.Status")" Width="100px">
                                <CellTemplate>
                                    @if (string.IsNullOrEmpty(context.Exceptions))
                                    {
                                        <StatusBadge Status="CGeneralStatus.Success" Style="min-width: 65px; justify-content: center;">@L("Common.Yes")</StatusBadge>
                                    }
                                    else
                                    {
                                        <StatusBadge Status="CGeneralStatus.Error" Style="min-width: 65px; justify-content: center;">@L("Common.No")</StatusBadge>
                                    }
                                </CellTemplate>
                            </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="@L("Common.Operations")" Width="50px"
                                             Alignment="ColumnAlignment.Right">
                                <CellTemplate>
                                    <button class="btn btn-sm btn-link p-0" @onclick="() => ViewDetails(context)"
                                            title="@L("Common.ViewDetails")">
                                        <i class="bi bi-info-circle"></i>
                                    </button>
                                </CellTemplate>
                            </DataTableColumn>
                        </ChildContent>
                    </DataTable>
                </div>
            </div>
        </div>

@code {
    [Inject] private IAuditLogAppService AuditLogService { get; set; } = default!;
    private List<AuditLogDto> _logs = new();
    private GetAuditLogsInput _input = new() { PageSize = 10, SorterKey = "ExecutionTime", SorterIsAsc = false };
    private long _totalCount;

    protected override async Task OnInitializedAsync() => await LoadLogsAsync();

    private async Task LoadLogsAsync()
    {
        try
        {
            var result = await AuditLogService.GetListAsync(_input);
            _logs = result.Items.ToList();
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            ToastNotification.Error(ex.Message);
        }
    }

    private async Task<DataTableResponse<AuditLogDto>> GetDataTableResponseAsync(DataTableRequest request)
    {
        _input.PageNumber = request.PageNumber;
        _input.PageSize = request.PageSize;
        await LoadLogsAsync();
        return new DataTableResponse<AuditLogDto> { Items = _logs, TotalCount = (int)_totalCount };
    }

    private async Task RefreshAsync() => await LoadLogsAsync();

    private void ViewDetails(AuditLogDto log) { /* Logic */ }
}
