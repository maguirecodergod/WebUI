@page "/tenant/users"
@namespace LHA.BlazorWasm.Modules.Tenant.Users.Pages
@inherits LHAComponentBase
@using LHA.BlazorWasm.Components.Breadcrumb
@using LHA.BlazorWasm.Components.Table
@using LHA.Shared.Contracts.Identity

<PageTitle>@L("Menu.Tenant.Users")</PageTitle>

<div class="user-list-container animate-fade-in px-4 py-2">
    @* ─── Breadcrumb ─── *@
    <div class="breadcrumb-wrapper mb-3">
        <LHABreadcrumb Items="_breadcrumbItems" Separator="/" />
    </div>

    @* ─── Header ─── *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight m-0">@L("Users.UserManagement")</h1>
            <p class="text-sm text-muted mt-1 m-0">@L("Users.UserManagementDescription")</p>
        </div>
        <LHAButton Style="CButtonStyle.Primary" Icon="bi bi-person-plus" OnClick="NavigateToCreate" 
                   Class="shadow-lg shadow-indigo-500/30">
            @L("Users.CreateUser")
        </LHAButton>
    </div>

    @* ─── User Table ─── *@
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <DataTable TItem="IdentityUserDto" 
                       Mode="DataTableMode.ServerSide"
                       ServerDataSource="GetDataTableResponseAsync"
                       DefaultPageSize="20"
                       Searchable="true" 
                       ShowToolbar="true"
                       KeySelector="@(x => x.Id)"
                       SearchPlaceholder="@L("Users.SearchPlaceholder")"
                       IsLoading="_isLoading">
                
                <ChildContent>
                    <DataTableColumn TItem="IdentityUserDto" Title="@L("Users.Username")">
                        <CellTemplate Context="item">
                            <div class="user-cell">
                                <div class="u-avatar">@item.UserName[0].ToString().ToUpper()</div>
                                <span class="font-semibold">@item.UserName</span>
                            </div>
                        </CellTemplate>
                    </DataTableColumn>

                    <DataTableColumn TItem="IdentityUserDto" Title="@L("Users.Email")" Property="@(x => x.Email)" />
                    
                    <DataTableColumn TItem="IdentityUserDto" Title="@L("Users.FullName")">
                        <CellTemplate Context="item">
                            <span>@item.Name @item.Surname</span>
                        </CellTemplate>
                    </DataTableColumn>

                    <DataTableColumn TItem="IdentityUserDto" Title="@L("Common.Actions")" Width="120px" Alignment="ColumnAlignment.Center">
                        <CellTemplate Context="item">
                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn-action edit" @onclick="() => NavigateToEdit(item.Id)" title="@L("Common.Edit")">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn-action delete" @onclick="() => DeleteUserAsync(item)" title="@L("Common.Delete")">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </CellTemplate>
                    </DataTableColumn>
                </ChildContent>

                <EmptyTemplate>
                    <div class="empty-state py-5 text-center">
                        <i class="bi bi-people text-muted display-4"></i>
                        <p class="mt-3 text-muted">@L("Users.NoUsersFound")</p>
                    </div>
                </EmptyTemplate>
            </DataTable>
        </div>
    </div>
</div>

<style>
    .user-list-container {
        animation: fadeIn 0.5s ease-out;
    }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .u-avatar {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 13px;
        box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
    }

    .btn-action {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        background: rgba(0,0,0,0.03);
    }

    .btn-action.edit:hover { background: rgba(99, 102, 241, 0.1); color: #6366f1; }
    .btn-action.delete:hover { background: rgba(239, 68, 68, 0.1); color: #ef4444; }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
