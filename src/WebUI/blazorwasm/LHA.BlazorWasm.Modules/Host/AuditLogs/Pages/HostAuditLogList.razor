@page "/host/audit-logs"
@namespace LHA.BlazorWasm.Modules.Host.AuditLogs.Pages
@inherits LhaComponentBase

<PageTitle>Audit Trails</PageTitle>

<div class="audit-log-page container-fluid p-4">
    @* Page Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1 fw-bold" style="color: var(--dt-text-primary, inherit);">Audit Trails</h1>
            <div class="small" style="color: var(--dt-text-secondary, inherit); opacity: 0.8;">Monitor and inspect
                system-wide activity logs.</div>
            </div>
            <div class="d-flex gap-2">
                <Button Style="CButtonStyle.Secondary" Size="CButtonSize.Medium" OnClick="RefreshAsync">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </Button>
                <Button Style="CButtonStyle.Danger" Size="CButtonSize.Medium" OnClick="ShowDeleteDialog">
                    <i class="bi bi-trash me-1"></i> Purge Logs
                </Button>
            </div>
        </div>

        @* Data Table Card *@
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="card-body p-0">
                <DataTable TItem="AuditLogDto" Items="_logs" Mode="DataTableMode.ServerSide" TotalCount="(int)_totalCount"
                           ServerDataSource="GetDataTableResponseAsync" DefaultPageSize="10" Searchable="true" ShowToolbar="true"
                           SelectionMode="SelectionMode.Multiple" KeySelector="@(x => x.Id)" TableId="@DataTableIds.AuditLogs">

                    <ToolbarTemplate>
                        <div class="small py-2 px-1" style="color: var(--dt-text-secondary);">API: service.audit.lha.io
                        </div>
                    </ToolbarTemplate>

                    <ChildContent>
                        <DataTableColumn TItem="AuditLogDto" Title="Identity (ID)" Width="100px" Sortable Filterable
                                         Property="@(x => x.Id)">
                            <CellTemplate>
                                <span class="fw-bold font-monospace small"
                                      style="color: var(--dt-accent);">@context.Id.ToString()[..8]...</span>
                            </CellTemplate>
                        </DataTableColumn>

                        <DataTableColumn TItem="AuditLogDto" Title="User ID" Width="100px" Sortable Filterable
                                         Property="@(x => x.UserId)">
                            <CellTemplate>
                                <span class="small" style="color: var(--dt-text-muted);">@(context.UserId?.ToString()[..4]
                                                                    ?? "ANON")</span>
                                </CellTemplate>
                            </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="Operation (Path)" Width="auto" Sortable Filterable
                                             Property="@(x => x.Url)">
                                <CellTemplate>
                                    <div class="fw-bold small" style="color: var(--dt-text-primary);">@context.Url</div>
                                </CellTemplate>
                            </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="User Name" Width="180px" Sortable Filterable
                                             Property="@(x => x.UserName)">
                                <CellTemplate>
                                    <div class="small" style="color: var(--dt-text-secondary);">@context.UserName</div>
                                </CellTemplate>
                            </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="Summary Preview" Width="auto">
                                <CellTemplate>
                                    <div class="text-truncate small" style="max-width: 300px; color: var(--dt-text-muted);">
                                        @(string.IsNullOrEmpty(context.Exceptions) ? "Transaction completed successfully..." :
                                        context.Exceptions)
                                    </div>
                                </CellTemplate>
                            </DataTableColumn>

                            <DataTableColumn TItem="AuditLogDto" Title="Operation" Width="100px"
                                             Alignment="ColumnAlignment.Right">
                                <CellTemplate>
                                    <div class="d-flex justify-content-end gap-1">
                                        <button class="btn btn-sm btn-icon-replica" @onclick="() => ViewDetails(context)"
                                                @onclick:stopPropagation>
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-icon-replica">
                                            <i class="bi bi-link-45deg"></i>
                                        </button>
                                    </div>
                                </CellTemplate>
                            </DataTableColumn>
                        </ChildContent>

                        <ExpandedRowTemplate>
                            <div class="p-4" style="background: var(--dt-sidebar-bg);">
                                <h6 class="fw-bold mb-3" style="color: var(--dt-text-primary);">Resource Trace (@context.Id)
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="small d-block" style="color: var(--dt-text-muted);">IP Address</label>
                                        <span style="color: var(--dt-text-secondary);">@context.ClientIpAddress</span>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small d-block" style="color: var(--dt-text-muted);">Browser Info</label>
                                        <span class="small" style="color: var(--dt-text-secondary);">@context.BrowserInfo</span>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small d-block" style="color: var(--dt-text-muted);">Execution Time</label>
                                        <span
                                        style="color: var(--dt-text-secondary);">@context.ExecutionTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                    </div>
                                </div>
                            </div>
                        </ExpandedRowTemplate>
                    </DataTable>
                </div>
            </div>
        </div>

        <style>
            .btn-icon-replica {
                width: 30px;
                height: 30px;
                padding: 0;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: #fff;
                border: 1px solid #e2e8f0;
                border-radius: 6px;
                color: #64748b;
                transition: all 0.2s;
            }

            .btn-icon-replica:hover {
                background: #f8fafc;
                color: #4f46e5;
                border-color: #cbd5e1;
            }
        </style>

@code {
    [Inject] private IAuditLogAppService AuditLogService { get; set; } = default!;
    private List<AuditLogDto> _logs = new();
    private GetAuditLogsInput _input = new()
    {
        PageSize = 10,
        SorterKey = nameof(AuditLogDto.ExecutionTime),
        SorterIsAsc = false
    };
    private long _totalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogsAsync();
    }

    private async Task LoadLogsAsync()
    {
        try
        {
            var result = await AuditLogService.GetListAsync(_input);
            _logs = result.Items.ToList();
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            ToastNotification.Error("Error: " + ex.Message);
        }
    }

    private async Task<DataTableResponse<AuditLogDto>> GetDataTableResponseAsync(DataTableRequest request)
    {
        _input.PageNumber = request.PageNumber;
        _input.PageSize = request.PageSize;
        // Search & Filter could be mapped here too
        await LoadLogsAsync();
        return new DataTableResponse<AuditLogDto> { Items = _logs, TotalCount = (int)_totalCount };
    }

    private async Task RefreshAsync() => await LoadLogsAsync();

    private void ViewDetails(AuditLogDto log)
    {
        // View details logic
    }

    private async Task ShowDeleteDialog()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Confirm log purge?"))
        {
            // Purge
        }
    }
}
