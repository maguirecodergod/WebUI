@* ──────────────────────────────────────────────────────────────
    DataTablePager — Full-featured pagination control.
    Features: First/Prev/Pages/Next/Last, page size selector, jump-to-page, info text.
   ────────────────────────────────────────────────────────────── *@
@namespace LHA.BlazorWasm.Components.Table
@inherits LhaComponentBase

<div class="dt-pager">
    @* ── Left: Info + Page Size ── *@
    <div class="dt-pager-column">
        <div class="dt-pager-info">
            @{
                var from = TotalCount == 0 ? 0 : (PageNumber - 1) * PageSize + 1;
                var to = Math.Min(PageNumber * PageSize, TotalCount);
            }
            <span>@L("Common.ShowingEntries", from, to, TotalCount)</span>
        </div>

        <div class="dt-pager-size">
            <span>@L("Common.RowsPerPage")</span>
            <div class="dt-pager-select-wrapper">
                <Select TValue="int" Options="@_pageSizeOptions" Value="PageSize" ValueChanged="SelectPageSize"
                        ShowClear="false" Class="dt-pager-select" Placement="CSelectPlacement.Top" />
            </div>
        </div>

    </div>

    @* ── Right: Navigation + Jump ── *@
    <div class="dt-pager-column">
        <div class="dt-pager-nav">
            @* Previous block *@
            <Tooltip Text="@L("Common.First")" Placement="CTooltipPlacement.Top">
                <Button Class="dt-pager-btn" Disabled="@(PageNumber <= 1)" Style="CButtonStyle.Light"
                        OnClick="() => GoTo(1)">«</Button>
            </Tooltip>

            <Tooltip Text="@L("Common.Prev")" Placement="CTooltipPlacement.Top">
                <Button Class="dt-pager-btn" Disabled="@(PageNumber <= 1)" Style="CButtonStyle.Light"
                        OnClick="() => GoTo(PageNumber - 1)">‹</Button>
            </Tooltip>

            @* Page Numbers *@
            @foreach (var item in GetPageItems())
            {
                if (item.IsEllipsis)
                {
                    <span class="dt-pager-btn-ellipsis">…</span>
                }
                else
                {
                    <Button Class="@($"dt-pager-btn {(item.Page == PageNumber ? "dt-pager-active" : string.Empty)}")"
                            Style="@(item.Page == PageNumber ? CButtonStyle.Primary : CButtonStyle.Light)"
                            OnClick="() => GoTo(item.Page)">
                        @item.Page
                    </Button>
                }
            }

            @* Next block *@
            <Tooltip Text="@L("Common.Next")" Placement="CTooltipPlacement.Top">
                <Button Class="dt-pager-btn" Disabled="@(PageNumber >= TotalPages)" Style="CButtonStyle.Light"
                        OnClick="() => GoTo(PageNumber + 1)">›</Button>
            </Tooltip>

            <Tooltip Text="@L("Common.Last")" Placement="CTooltipPlacement.Top">
                <Button Class="dt-pager-btn" Disabled="@(PageNumber >= TotalPages)" Style="CButtonStyle.Light"
                        OnClick="() => GoTo(TotalPages)">»</Button>
            </Tooltip>
        </div>


        <div class="dt-pager-jump">
            <span>@L("Common.GoToPage")</span>
            <input type="number" min="1" max="@TotalPages" value="@PageNumber" @onchange="OnJumpChange"
                   class="dt-pager-jump-input" />
        </div>
    </div>
</div>

@code {
    [Parameter] public int PageNumber { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int[] PageSizes { get; set; } = [10, 25, 50, 100];
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private List<SelectOption<int>> _pageSizeOptions = new();

    protected override void OnInitialized()
    {
        _pageSizeOptions = PageSizes.Select(s => new SelectOption<int> { Value = s, Label = s.ToString() }).ToList();
    }

    private bool _pageSizeDropdownOpen;

    private void TogglePageSizeDropdown() => _pageSizeDropdownOpen = !_pageSizeDropdownOpen;

    private async Task SelectPageSize(int size)
    {
        _pageSizeDropdownOpen = false;
        if (size != PageSize && size > 0)
            await OnPageSizeChanged.InvokeAsync(size);
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)TotalCount / PageSize));

    private async Task GoTo(int page)
    {
        page = Math.Max(1, Math.Min(page, TotalPages));
        if (page != PageNumber)
            await OnPageChanged.InvokeAsync(page);
    }

    private async Task OnJumpChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var page))
            await GoTo(page);
    }

    private IEnumerable<PagerItem> GetPageItems()
    {
        const int window = 2;
        var total = TotalPages;

        if (total <= 7)
        {
            for (var i = 1; i <= total; i++)
                yield return new PagerItem(i);
            yield break;
        }

        yield return new PagerItem(1);

        var start = Math.Max(2, PageNumber - window);
        var end = Math.Min(total - 1, PageNumber + window);

        if (start > 2) yield return PagerItem.Ellipsis;

        for (var i = start; i <= end; i++)
            yield return new PagerItem(i);

        if (end < total - 1) yield return PagerItem.Ellipsis;

        yield return new PagerItem(total);
    }

    private readonly record struct PagerItem(int Page, bool IsEllipsis = false)
    {
        public static PagerItem Ellipsis => new(0, true);
    }
}
