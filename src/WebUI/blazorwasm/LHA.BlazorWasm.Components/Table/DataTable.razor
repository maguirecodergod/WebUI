@* ═══════════════════════════════════════════════════════════════════
    DataTable<TItem> — Enterprise-grade reusable data table component.
   ═══════════════════════════════════════════════════════════════════ *@
@namespace LHA.BlazorWasm.Components.Table
@using LHA.BlazorWasm.Components.Form
@using LHA.BlazorWasm.Components.Tooltip
@inherits LhaComponentBase
@typeparam TItem
@implements IDisposable

@{
    var visibleCols = VisibleColumns;
}

<div class="dt-container @ThemeClass @CssClass" style="margin:0;" @attributes="AdditionalAttributes">

    @* ════════════ TOOLBAR ════════════ *@
    @if (ShowToolbar)
    {
        <div class="dt-toolbar">
            @* Left-side slot / Info *@
            <div class="dt-toolbar-start">
                @if (ToolbarTemplate is not null)
                {
                    @ToolbarTemplate
                }
            </div>

            @* Right-side Actions *@
            @if (Searchable)
            {
                <div class="dt-search" style="min-width: 260px;">
                    <CInput TValue="string" Value="@_searchInput" ValueChanged="OnSearchValueChanged"
                            ValueExpression="@(() => _searchInput)" Placeholder="@Localizer.L("DataTable.Search")" Clearable="true"
                            Size="CInputSize.Small">
                        <IconLeft>
                            <i class="bi bi-search"></i>
                        </IconLeft>
                    </CInput>
                </div>
            }

            @if (_columns.Any(c => c.Filterable))
            {
                <Tooltip Text="@Localizer.L("DataTable.Filters")" Placement="CTooltipPlacement.Top">
                    <Button Class="@($"dt-toolbar-btn {(_filterSidebarOpen ? "dt-toolbar-btn-active" : string.Empty)}")"
                            Style="CButtonStyle.Light" OnClick="ToggleFilterSidebar">
                        <i class="bi bi-filter"></i>
                    </Button>
                </Tooltip>
            }

            @if (ShowColumnToggle && _columns.Count > 0)
            {
                <div style="position: relative;">
                    <Tooltip Text="@Localizer.L("DataTable.Columns")" Placement="CTooltipPlacement.Top">
                        <Button Class="dt-toolbar-btn" Style="CButtonStyle.Light" OnClick="ToggleColumnDropdown"
                                OnClick:stopPropagation="true">
                            <i class="bi bi-columns-gap"></i>
                        </Button>
                    </Tooltip>
                    @if (_columnToggleOpen)
                    {
                        <div class="dt-col-toggle-list" @onclick:stopPropagation>
                            @foreach (var col in _columns)
                            {
                                <div class="dt-col-toggle-item" @onclick="async () => await ToggleColumnVisibility(col, !col.Visible)">
                                    <input type="checkbox" checked="@col.Visible" />
                                    <span>@col.Title</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <Tooltip Text="@Localizer.L("DataTable.Refresh")" Placement="CTooltipPlacement.Top">
                <Button Class="dt-toolbar-btn" Style="CButtonStyle.Light" OnClick="RefreshAsync" IsLoading="@_isLoading">
                    <i class="bi bi-arrow-clockwise"></i>
                </Button>
            </Tooltip>
        </div>
    }

    @* ════════════ TABLE ════════════ *@
    <div class="dt-wrapper" style="@(MaxHeight is not null ? $"max-height:{MaxHeight};" : string.Empty)">
        <table class="dt-table">
            <thead>
                <tr class="dt-header-row">
                    @if (SelectionMode != SelectionMode.None)
                    {
                        <th class="dt-header-cell dt-col-select" style="text-align: center;">
                            @if (SelectionMode == SelectionMode.Multiple)
                            {
                                <input type="checkbox" checked="@_allPageSelected"
                                       @onchange="async () => await ToggleSelectAllPage()" />
                            }
                        </th>
                    }
                    @if (ExpandedRowTemplate is not null)
                    {
                        <th class="dt-header-cell dt-col-expand"></th>
                    }

                    @foreach (var col in visibleCols)
                    {
                        var sort = GetSort(col.Field);
                        <th class="dt-header-cell @(col.Sortable ? "dt-sortable" : string.Empty)"
                            style="@col.GetColumnStyle()"
                            @onclick="async () => { if (col.Sortable) await ToggleSort(col.Field); }">

                            @if (col.HeaderTemplate is not null)
                            {
                                @col.HeaderTemplate
                            }
                            else
                            {
                                <span>@col.Title</span>
                            }

                            @if (col.Sortable)
                            {
                                <span class="dt-sort-icon">
                                    @if (sort.Direction == SortDirection.Ascending)
                                    {
                                        <i class="bi bi-caret-up-fill dt-svg-icon"></i>
                                    }
                                    else if (sort.Direction == SortDirection.Descending)
                                    {
                                        <i class="bi bi-caret-down-fill dt-svg-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up dt-svg-icon" style="opacity: 0.3;"></i>
                                    }
                                </span>
                            }
                        </th>
                    }
                </tr>
            </thead>

            <tbody>
                @if (SelectionMode == SelectionMode.Multiple && _allPageSelected && _totalCount > _displayItems.Count)
                {
                    <tr class="dt-selection-msg-row">
                        <td colspan="@_totalColumns" class="dt-cell" style="padding: 0.5rem 1rem;">
                            <div class="dt-selection-msg">
                                @if (!_allEntireDatasetSelected)
                                {
                                    <span>@string.Format(Localizer.L("DataTable.AllPageSelected"), _displayItems.Count)</span>
                                    <Button Style="CButtonStyle.Link" Size="CButtonSize.Small" Class="ms-2"
                                            OnClick="SelectAllEntireDataset">
                                        @string.Format(Localizer.L("DataTable.SelectAllDataset"), _totalCount)
                                    </Button>
                                }
                                else
                                {
                                    <span>@string.Format(Localizer.L("DataTable.AllDatasetSelected"), _totalCount)</span>
                                    <Button Style="CButtonStyle.Link" Size="CButtonSize.Small" Class="ms-2"
                                            OnClick="ClearSelectionAsync">
                                        @Localizer.L("DataTable.ClearSelection")
                                    </Button>
                                }
                            </div>
                        </td>
                    </tr>
                }

                @if (_isLoading && _displayItems.Count == 0)
                {
                    @for (var i = 0; i < 5; i++)
                    {
                        <tr class="dt-row">
                            @for (var j = 0; j < (visibleCols.Count + (SelectionMode != SelectionMode.None ? 1 : 0) +
                    (ExpandedRowTemplate is not null ? 1 : 0)); j++)
                            {
                                <td class="dt-cell">
                                    <Skeleton Height="1.25rem" Width="100%" />
                                </td>
                            }
                        </tr>
                    }
                }
                else if (_displayItems.Count == 0)
                {
                    <tr>
                        <td colspan="@_totalColumns" class="dt-cell" style="text-align: center; padding: 3rem;">
                            @if (EmptyTemplate is not null)
                            {
                                @EmptyTemplate
                            }
                            else
                            {
                                <text>@Localizer.L("DataTable.NoData")</text>
                            }
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in _displayItems)
                    {
                        <tr class="dt-row dt-row-hoverable @(IsSelected(item) ? "dt-row-selected" : string.Empty)"
                            @onclick="async () => await HandleRowClickInternal(item)">

                            @if (SelectionMode != SelectionMode.None)
                            {
                                <td class="dt-cell" style="text-align: center;" @onclick:stopPropagation>
                                    @if (SelectionMode == SelectionMode.Multiple)
                                    {
                                        <input type="checkbox" checked="@IsSelected(item)"
                                               @onchange="async e => await HandleSelectionToggle(item, e.Value)" />
                                    }
                                    else
                                    {
                                        <input type="radio" checked="@IsSelected(item)"
                                               @onchange="async e => await HandleSelectionToggle(item, e.Value)" />
                                    }
                                </td>
                            }

                            @if (ExpandedRowTemplate is not null)
                            {
                                <td class="dt-cell dt-col-expand" style="text-align: center;" @onclick:stopPropagation>
                                    <button type="button" class="dt-expand-btn @(IsExpanded(item) ? "dt-expanded" : string.Empty)"
                                            @onclick="() => ToggleExpand(item)"><i class="bi bi-chevron-right"></i></button>
                                </td>
                            }

                            @foreach (var col in visibleCols)
                            {
                                <td class="dt-cell @col.GetCellCss(item)" style="@GetCellInlineStyle(col, item)">
                                    @if (col.CellTemplate is not null)
                                    {
                                        @col.CellTemplate(item)
                                    }
                                    else
                                    {
                                        @col.GetDisplayValue(item)
                                    }
                                </td>
                            }
                        </tr>
                        @if (IsExpanded(item) && ExpandedRowTemplate is not null)
                        {
                            <tr class="dt-expanded-row">
                                <td colspan="@_totalColumns" style="padding: 0;">@ExpandedRowTemplate(item)</td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>
    </div>

    @* ════════════ PAGER ════════════ *@
    @if (ShowPager)
    {
        <DataTablePager PageNumber="@_request.PageNumber" PageSize="@_request.PageSize" TotalCount="@_totalCount"
                        PageSizes="@PageSizes" OnPageChanged="HandlePageChanged" OnPageSizeChanged="HandlePageSizeChanged" />
    }
</div>

@if (_columns.Any(c => c.Filterable))
{
    @if (_filterSidebarOpen)
    {
        <div class="dt-sidebar-overlay" @onclick="CloseFilterSidebar"></div>
    }

    <aside class="dt-sidebar @ThemeClass @(_filterSidebarOpen ? "dt-sidebar-open" : string.Empty)">
        <div class="dt-sidebar-header">
            <h3 class="dt-sidebar-title">
                <i class="bi bi-filter"></i>
                @Localizer.L("DataTable.Filters")
            </h3>
            <button type="button" @onclick="CloseFilterSidebar"
                    style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">✕</button>
        </div>
        <div class="dt-sidebar-body">
            @foreach (var col in _columns.Where(c => c.Filterable))
            {
                <div class="dt-sidebar-filter-group">
                    <label class="dt-sidebar-label">@col.Title</label>
                    @RenderFilterInput(col)
                </div>
            }
        </div>
        <div class="dt-sidebar-footer">
            <Button Style="CButtonStyle.Light" Size="CButtonSize.Small" OnClick="ClearAllFiltersAsync" Class="flex-grow-1">
                @Localizer.L("DataTable.Clear")
            </Button>
            <Button Style="CButtonStyle.Primary" Size="CButtonSize.Small" OnClick="ApplyFiltersAsync" Class="flex-grow-1">
                @Localizer.L("DataTable.Apply")
            </Button>
        </div>
    </aside>
}

<div style="display:none">
    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private RenderFragment RenderFilterInput(ColumnDefinition<TItem> col) => __builder =>
    {
        // ── Custom template takes priority ────────────────────
        if (col.FilterTemplate is not null)
        {
            @col.FilterTemplate
            return;
        }

        // ── Built-in defaults ────────────────────────────────
        switch (col.FilterType)
        {
            case FilterType.Text:
                <CInput TValue="string" Value="@GetStagedFilterValue(col.Field)"
                        ValueChanged="@(v => SetStagedFilter(col.Field, v, FilterType.Text))" ValueExpression="@(() => _dummyFilter)"
                        Placeholder="@col.Title" Clearable="true" Size="CInputSize.Small" />
                break;
            case FilterType.Select:
                <select class="dt-filter-input" value="@GetStagedFilterValue(col.Field)"
                        @onchange="e => SetStagedFilter(col.Field, e.Value?.ToString(), FilterType.Select, FilterOperator.Equals)">
                    <option value="">@Localizer.L("DataTable.All")</option>
                    @if (col.FilterOptions is not null)
                    {
                        @foreach (var opt in col.FilterOptions)
                        {
                            <option value="@opt.Value">@opt.Label</option>
                        }
                    }
                </select>
                break;
        }
    };
}
