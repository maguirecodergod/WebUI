@using LHA.BlazorWasm.Components.ThemeSwitch
@using LHA.BlazorWasm.Components.LanguageSelector

<header class="topbar @(IsSticky ? "sticky" : string.Empty)">
    @* --- Left Section --- *@
    <div class="topbar-section left">
        @if (LeftContent != null)
        {
            @LeftContent
        }
        else
        {
            <div class="topbar-group">
                <a href="/" class="topbar-logo" aria-label="Go to homepage">
                    <div class="logo-icon">
                        @if (!string.IsNullOrEmpty(LogoSvg))
                        {
                            @((MarkupString)LogoSvg)
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
                            </svg>
                        }
                    </div>
                    <span class="logo-text">@AppName</span>
                </a>
            </div>
        }
    </div>

    @* --- Center Section --- *@
    <div class="topbar-section center">
        @if (CenterContent != null)
        {
            @CenterContent
        }
        else
        {
            <div class="topbar-search-wrapper">
                <button class="search-trigger" @onclick="OpenCommandPalette" aria-label="Open Search">
                    <span class="search-trigger-content">
                        <i class="bi bi-search"></i>
                        <span class="search-placeholder">@L("Topbar.SearchPlaceholder")</span>
                    </span>
                    <span class="search-kbd">⌘K</span>
                </button>

                @if (TopbarService.State.Breadcrumbs.Any())
                {
                    <LHABreadcrumb Items="TopbarService.State.Breadcrumbs" Class="breadcrumb-desktop" />
                }
            </div>
        }
    </div>

    @* --- Right Section --- *@
    <div class="topbar-section right">
        @if (RightContent != null)
        {
            @RightContent
        }
        else
        {
            <div class="topbar-actions">
                @if (TopbarService.State.IsLoading)
                {
                    <div class="loading-skeletons">
                        <Skeleton Variant="CSkeletonVariant.Circular" Width="36px" Height="36px" />
                        <Skeleton Variant="CSkeletonVariant.Circular" Width="36px" Height="36px" />
                        <div class="user-block-loading">
                            <Skeleton Variant="CSkeletonVariant.Circular" Width="32px" Height="32px" />
                        </div>
                    </div>
                }
                else
                {
                    @* Dynamic items usually hidden on mobile or moving to menu *@
                    <div class="dynamic-actions desktop-only" @onclick:stopPropagation>
                        @foreach (var item in TopbarService.State.DynamicItems)
                        {
                            <TopbarItem Item="item" />
                        }
                    </div>

                    <button class="icon-button mobile-search-button" @onclick="OpenCommandPalette" aria-label="Open search">
                        <i class="bi bi-search"></i>
                    </button>

                    <NotificationBell Count="TopbarService.State.UnreadCount" />

                    <div class="settings-actions tablet-desktop-only" @onclick:stopPropagation>
                        <ThemeSwitch Variant="CThemeSwitchVariant.Toggle" />
                        <LanguageSelector Mode="LHA.BlazorWasm.Services.Localization.CLanguageSelectorMode.Dropdown"
                                          ShowFlags="true" ShowNames="false"
                                          Variant="LHA.BlazorWasm.Components.Select.CSelectVariant.Minimalist"
                                          Size="LHA.BlazorWasm.Components.Form.CInputSize.Small" />
                    </div>
                    @* User Profile *@
                    <div class="user-profile-container">
                        <div class="user-profile-toggle @(_isProfileOpen ? "active" : string.Empty)" @onclick="ToggleProfile"
                             @onclick:stopPropagation>
                            <div class="user-avatar">
                                @if (!string.IsNullOrEmpty(TopbarService.State.User?.AvatarUrl))
                                {
                                    <img src="@TopbarService.State.User.AvatarUrl" alt="@TopbarService.State.User.DisplayName" />
                                }
                                else
                                {
                                    <span>@(TopbarService.State.User?.DisplayName.FirstOrDefault().ToString().ToUpper() ??
                                                                                                                                                    "U")</span>
                                    }
                                </div>
                                <div class="user-info-text">
                                    <span class="user-name">@(TopbarService.State.User?.DisplayName ?? "Guest")</span>
                                    <span class="user-role">@(TopbarService.State.User?.Role ?? "Anonymous")</span>
                                </div>
                                <i class="bi bi-chevron-down dropdown-arrow"></i>
                            </div>

                            @* Profile Dropdown - Now a sibling to the toggle, not a child of the clickable area *@
                            <div class="topbar-dropdown profile-menu @(_isProfileOpen ? "show" : "")" @onclick:stopPropagation>
                                <div class="dropdown-header mobile-only">
                                    <div class="mobile-user-details">
                                        <span class="user-name">@(TopbarService.State.User?.DisplayName ?? "Guest")</span>
                                        <span class="user-role">@(TopbarService.State.User?.Role ?? "Anonymous")</span>
                                    </div>
                                </div>

                                @* Dynamic items in mobile menu *@
                                @if (TopbarService.State.DynamicItems.Any())
                                {
                                    <div class="dropdown-section mobile-only">
                                        <div class="dropdown-subtitle">Actions</div>
                                        @foreach (var item in TopbarService.State.DynamicItems)
                                        {
                                            <div class="dropdown-item">
                                                <TopbarItem Item="item" />
                                            </div>
                                        }
                                        <div class="dropdown-divider"></div>
                                    </div>
                                }

                                <div class="dropdown-item" @onclick='(() => Navigation.NavigateTo("/profile"))'>
                                    <i class="bi bi-person"></i>
                                    <span>Profile</span>
                                </div>
                                <div class="dropdown-item" @onclick='(() => Navigation.NavigateTo("/settings"))'>
                                    <i class="bi bi-gear"></i>
                                    <span>Settings</span>
                                </div>
                                <div class="dropdown-divider"></div>
                                @* Mobile only actions in profile menu *@
                                <div class="dropdown-subtitle mobile-only">Appearance</div>
                                <div class="dropdown-item mobile-only" @onclick:stopPropagation>
                                    <ThemeSwitch Variant="CThemeSwitchVariant.Toggle" />
                                    <span>Dark Mode</span>
                                </div>
                                <div class="dropdown-item mobile-only" @onclick:stopPropagation>
                                    <LanguageSelector Mode="LHA.BlazorWasm.Services.Localization.CLanguageSelectorMode.Dropdown"
                                                      ShowFlags="true" ShowNames="true" />
                                </div>
                                <div class="dropdown-divider mobile-only"></div>

                                <div class="dropdown-item logout" @onclick="HandleLogout">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Logout</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            }
        </div>
    </header>
    <CommandPalette @bind-IsVisible="_isSearchOpen" />

    @if (_isProfileOpen || _isNotificationOpen)
    {
        <div class="topbar-backdrop" @onclick="CloseDropdowns"></div>
    }

