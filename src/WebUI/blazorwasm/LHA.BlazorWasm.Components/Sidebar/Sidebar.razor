@namespace LHA.BlazorWasm.Components.Sidebar
@using LHA.BlazorWasm.Components.Sidebar.Models
@implements IAsyncDisposable

<div @ref="_sidebarRef"
     class="lha-sidebar @StateClass @HoverExpandClass @ThemeService.ThemeClass @(_isDragging ? "lha-sidebar--dragging" : "")"
     style="@SidebarStyle" @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave">

    @* ── Mobile Overlay Backdrop ── *@
    @if (State == CSidebarState.Hidden && _mobileOpen)
    {
        <div class="lha-sidebar__overlay lha-sidebar__overlay--visible" @onclick="CloseMobileDrawer"></div>
    }

    <nav class="lha-sidebar__nav @(_mobileOpen ? "lha-sidebar__nav--open" : "")" role="navigation"
         aria-label="@Localizer.L("Sidebar.AriaLabel")">

        @* ── Header / Brand Area ── *@
        @if (HeaderTemplate != null)
        {
            <div class="lha-sidebar__header">
                @HeaderTemplate
            </div>
        }

        @* ── Scrollable Navigation Items ── *@
        <div class="lha-sidebar__content">
            @if (Items != null)
            {
                @foreach (var item in Items.Where(IsAuthorized).OrderBy(i => i.Order))
                {
                    <SidebarItem Item="@item" Depth="0" CurrentState="@EffectiveState" ExpandedIds="@_expandedIds"
                                 ActiveItemId="@_activeItemId" OnToggleExpand="@HandleToggleExpand" OnItemClicked="@HandleItemClick" />
                }
            }
        </div>

        @* ── Footer Area ── *@
        @if (FooterTemplate != null)
        {
            <div class="lha-sidebar__footer">
                @FooterTemplate
            </div>
        }
    </nav>

    @* ── Resize Handle (Desktop only, Expanded state) ── *@
    @if (Resizable && EffectiveState == CSidebarState.Expanded)
    {
        <div class="lha-sidebar__resize-handle" @onmousedown="StartResize" @onmousedown:preventDefault>
            <Tooltip Text="@Localizer.L("Sidebar.ResizeTooltip")" Placement="CTooltipPlacement.Left"
                     Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                <div class="lha-sidebar__resize-indicator"></div>
            </Tooltip>
        </div>
    }

    @* ── Internal Toggle Button (Desktop only) ── *@
    @if (ShowToggle && State != CSidebarState.Hidden)
    {
        <Tooltip Text="@(State == CSidebarState.Expanded ? Localizer.L("Sidebar.Collapse") : Localizer.L("Sidebar.Expand"))"
                 Placement="CTooltipPlacement.Left" Class="lha-sidebar-internal-toggle-tooltip">
            <LHAButton Type="CButtonType.Button" Class="lha-sidebar__internal-toggle" OnClick="HandleInternalToggle"
                       Style="CButtonStyle.Ghost" aria-label="Toggle Sidebar">
                @if (State == CSidebarState.Expanded)
                {
                    <i class="bi bi-chevron-left"></i>
                }
                else
                {
                    <i class="bi bi-chevron-right"></i>
                }
            </LHAButton>
        </Tooltip>
    }
</div>
