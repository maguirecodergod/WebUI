@namespace LHA.BlazorWasm.Components.Emoji

<div class="lha-emoji-category-bar">
    @foreach (var category in Enum.GetValues<EmojiCategory>().Where(c => c != EmojiCategory.Recent))
    {
        <Button Type="ButtonType.Button" Class=@($"category-btn {(ActiveCategory == category ? "active" : string.Empty)}")
            OnClick="() => OnCategorySelected.InvokeAsync(category)" Title="@category.ToString()">
            <i class="@GetCategoryIcon(category)"></i>
        </Button>
    }
</div>

@code {
    [Parameter] public EmojiCategory ActiveCategory { get; set; }
    [Parameter] public EventCallback<EmojiCategory> OnCategorySelected { get; set; }

    private string GetCategoryIcon(EmojiCategory category) => category switch
    {
        EmojiCategory.Smileys => "far fa-smile",
        EmojiCategory.People => "fas fa-user",
        EmojiCategory.Animals => "fas fa-paw",
        EmojiCategory.Food => "fas fa-utensils",
        EmojiCategory.Travel => "fas fa-plane",
        EmojiCategory.Objects => "fas fa-lightbulb",
        EmojiCategory.Symbols => "fas fa-hashtag",
        EmojiCategory.Flags => "fas fa-flag",
        _ => "fas fa-clock"
    };
}
