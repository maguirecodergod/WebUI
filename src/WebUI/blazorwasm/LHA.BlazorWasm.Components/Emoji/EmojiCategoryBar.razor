@namespace LHA.BlazorWasm.Components.Emoji

<div class="lha-emoji-category-bar">
    @foreach (var category in Enum.GetValues<CEmojiCategory>().Where(c => c != CEmojiCategory.Recent))
    {
        <LHAButton Type="CButtonType.Button" Class=@($"category-btn {(ActiveCategory == category ? "active" :
                                              string.Empty)}") OnClick="() => OnCategorySelected.InvokeAsync(category)" title="@category.ToString()">
            <i class="@GetCategoryIcon(category)"></i>
        </LHAButton>
    }
</div>

@code {
    [Parameter] public CEmojiCategory ActiveCategory { get; set; }
    [Parameter] public EventCallback<CEmojiCategory> OnCategorySelected { get; set; }

    private string GetCategoryIcon(CEmojiCategory category) => category switch
    {
        CEmojiCategory.Smileys => "far fa-smile",
        CEmojiCategory.People => "fas fa-user",
        CEmojiCategory.Animals => "fas fa-paw",
        CEmojiCategory.Food => "fas fa-utensils",
        CEmojiCategory.Travel => "fas fa-plane",
        CEmojiCategory.Objects => "fas fa-lightbulb",
        CEmojiCategory.Symbols => "fas fa-hashtag",
        CEmojiCategory.Flags => "fas fa-flag",
        _ => "fas fa-clock"
    };
}
