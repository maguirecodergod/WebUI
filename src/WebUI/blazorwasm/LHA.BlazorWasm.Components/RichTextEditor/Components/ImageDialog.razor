@namespace LHA.BlazorWasm.Components.RichTextEditor.Components

@if (IsVisible)
{
    <div class="rte-dialog-overlay" @onclick="Close">
        <div class="rte-dialog" @onclick:stopPropagation>
            <div class="rte-dialog-header">
                <h3>@Localizer.L("Editor.Insert Image")</h3>
                <LHAButton Style="CButtonStyle.Link" Class="rte-dialog-close" OnClick="Close">
                    <i class="bi bi-x"></i>
                </LHAButton>
            </div>
            <div class="rte-dialog-body">
                <div class="rte-form-group">
                    <label>@Localizer.L("Editor.Image URL")</label>
                    <input type="url" class="rte-input" @bind="ImageUrl"
                           placeholder='@Localizer.L("Editor.https://example.com/image.jpg")' />
                </div>
                <div class="rte-form-group">
                    <label>@Localizer.L("Editor.Alt Text")</label>
                    <input type="text" class="rte-input" @bind="AltText"
                           placeholder='@Localizer.L("Editor.Describe the image")' />
                </div>
                <div class="rte-form-row">
                    <div class="rte-form-group">
                        <label>@Localizer.L("Editor.Width")</label>
                        <input type="text" class="rte-input" @bind="Width"
                               placeholder='@Localizer.L("Editor.e.g., 400px or 100%")' />
                    </div>
                    <div class="rte-form-group">
                        <label>@Localizer.L("Editor.Height")</label>
                        <input type="text" class="rte-input" @bind="Height" placeholder='@Localizer.L("Editor.auto")' />
                    </div>
                </div>
            </div>
            <div class="rte-dialog-footer">
                <LHAButton Style="CButtonStyle.Secondary" OnClick="Close">@Localizer.L("Editor.Cancel")</LHAButton>
                <LHAButton Style="CButtonStyle.Primary" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(ImageUrl)">
                    @Localizer.L("Editor.Insert Image")</LHAButton>
                </div>
            </div>
        </div>
    }
