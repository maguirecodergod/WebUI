@namespace LHA.BlazorWasm.Components.RichTextEditor.Components
@using LHA.BlazorWasm.Components.RichTextEditor.Models

<div class="rte-toolbar">
    @* ===== ROW 1: Text Formatting & Alignment ===== *@
    <div class="rte-toolbar-row">
        @* Bold / Italic / Underline *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Bold" Tooltip='@Localizer.L("Editor.Bold (Ctrl+B)")' IsActive="@State.IsBold"
                           OnClick="@(() => ExecuteCommand("bold"))" />
            <ToolbarButton SvgIcon="@Icons.Italic" Tooltip='@Localizer.L("Editor.Italic (Ctrl+I)")' IsActive="@State.IsItalic"
                           OnClick="@(() => ExecuteCommand("italic"))" />
            <ToolbarButton SvgIcon="@Icons.Underline" Tooltip='@Localizer.L("Editor.Underline (Ctrl+U)")' IsActive="@State.IsUnderline"
                           OnClick="@(() => ExecuteCommand("underline"))" />
        </div>

        <ToolbarSeparator />

        @* Font Color / Background Color *@
        <div class="rte-toolbar-group">
            <ToolbarDropdown SvgIcon="@Icons.FontColor" Tooltip='@Localizer.L("Editor.Font Color")' @ref="_foreColorDropdown">
                <ColorPickerPopup SelectedColor="@State.FontColor"
                                  OnColorSelected="@OnForeColor" />
            </ToolbarDropdown>
            <ToolbarDropdown SvgIcon="@Icons.BackColor" Tooltip='@Localizer.L("Editor.Highlight Color")' @ref="_backColorDropdown">
                <ColorPickerPopup SelectedColor="@State.BackColor"
                                  OnColorSelected="@OnBackColor" />
            </ToolbarDropdown>
        </div>

        <ToolbarSeparator />

        @* Alignment *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.AlignLeft" Tooltip='@Localizer.L("Editor.Align Left")' IsActive="@(State.Alignment == "left")"
                           OnClick="@(() => ExecuteCommand("justifyLeft"))" />
            <ToolbarButton SvgIcon="@Icons.AlignCenter" Tooltip='@Localizer.L("Editor.Align Center")' IsActive="@(State.Alignment == "center")"
                           OnClick="@(() => ExecuteCommand("justifyCenter"))" />
            <ToolbarButton SvgIcon="@Icons.AlignRight" Tooltip='@Localizer.L("Editor.Align Right")' IsActive="@(State.Alignment == "right")"
                           OnClick="@(() => ExecuteCommand("justifyRight"))" />
            <ToolbarButton SvgIcon="@Icons.AlignJustify" Tooltip='@Localizer.L("Editor.Justify")' IsActive="@(State.Alignment == "justify")"
                           OnClick="@(() => ExecuteCommand("justifyFull"))" />
        </div>

        <ToolbarSeparator />

        @* Lists *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.OrderedList" Tooltip='@Localizer.L("Editor.Numbered List")' IsActive="@State.IsOrderedList"
                           OnClick="@(() => ExecuteCommand("insertOrderedList"))" />
            <ToolbarButton SvgIcon="@Icons.UnorderedList" Tooltip='@Localizer.L("Editor.Bullet List")' IsActive="@State.IsUnorderedList"
                           OnClick="@(() => ExecuteCommand("insertUnorderedList"))" />
        </div>

        <ToolbarSeparator />

        @* Indent / Outdent *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Outdent" Tooltip='@Localizer.L("Editor.Decrease Indent")'
                           OnClick="@(() => ExecuteCommand("outdent"))" />
            <ToolbarButton SvgIcon="@Icons.Indent" Tooltip='@Localizer.L("Editor.Increase Indent")'
                           OnClick="@(() => ExecuteCommand("indent"))" />
        </div>

        <ToolbarSeparator />

        @* Blockquote *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Blockquote" Tooltip='@Localizer.L("Editor.Blockquote")'
                           OnClick="@(() => ExecuteCommand("formatBlock", "blockquote"))" />
        </div>
    </div>

    @* ===== ROW 2: Editing Tools, Insert, View ===== *@
    <div class="rte-toolbar-row">
        @* Clear / Cut / Copy / Paste *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.ClearFormat" Tooltip='@Localizer.L("Editor.Clear Formatting")'
                           OnClick="@(() => ExecuteCommand("removeFormat"))" />
            <ToolbarButton SvgIcon="@Icons.Cut" Tooltip='@Localizer.L("Editor.Cut (Ctrl+X)")'
                           OnClick="@(() => ExecuteCommand("cut"))" />
            <ToolbarButton SvgIcon="@Icons.Copy" Tooltip='@Localizer.L("Editor.Copy (Ctrl+C)")'
                           OnClick="@(() => ExecuteCommand("copy"))" />
            <ToolbarButton SvgIcon="@Icons.Paste" Tooltip='@Localizer.L("Editor.Paste (Ctrl+V)")'
                           OnClick="@(() => ExecuteCommand("paste"))" />
        </div>

        <ToolbarSeparator />

        @* Undo / Redo *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Undo" Tooltip='@Localizer.L("Editor.Undo (Ctrl+Z)")'
                           OnClick="@(() => ExecuteCommand("undo"))" />
            <ToolbarButton SvgIcon="@Icons.Redo" Tooltip='@Localizer.L("Editor.Redo (Ctrl+Y)")'
                           OnClick="@(() => ExecuteCommand("redo"))" />
        </div>

        <ToolbarSeparator />

        @* Link / Unlink *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Link" Tooltip='@Localizer.L("Editor.Insert Link")'
                           OnClick="@ShowLinkDialog" />
            <ToolbarButton SvgIcon="@Icons.Unlink" Tooltip='@Localizer.L("Editor.Remove Link")'
                           OnClick="@(() => ExecuteCommand("unlink"))" />
        </div>

        <ToolbarSeparator />

        @* Special Characters *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.SpecialChars" Tooltip='@Localizer.L("Editor.Horizontal Rule")'
                           OnClick="@(() => ExecuteCommand("insertHorizontalRule"))" />
        </div>

        <ToolbarSeparator />

        @* Table / Image / Video *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Table" Tooltip='@Localizer.L("Editor.Insert Table")'
                           OnClick="@ShowTableDialog" />
            <ToolbarDropdown SvgIcon="@Icons.Image" Tooltip='@Localizer.L("Editor.Insert Image")' @ref="_imageDropdown">
                <div class="rte-menu-list">
                    <button class="rte-menu-item" @onclick="OnUploadClick">
                        <span class="rte-menu-icon" style="color: #1a73e8;">@((MarkupString)Icons.Upload)</span>
                        <span>@Localizer.L("Editor.Upload")</span>
                    </button>
                    <button class="rte-menu-item" @onclick="OnCameraClick">
                        <span class="rte-menu-icon" style="color: #6b7280;">@((MarkupString)Icons.Camera)</span>
                        <span>@Localizer.L("Editor.Camera")</span>
                    </button>
                    <button class="rte-menu-item" @onclick="() => { _imageDropdown?.Close(); ShowImageDialog(); }">
                        <span class="rte-menu-icon" style="color: #6b7280;">@((MarkupString)Icons.Image)</span>
                        <span>@Localizer.L("Editor.By Url")</span>
                    </button>
                    <button class="rte-menu-item" @onclick="OnDragDropClick">
                        <span class="rte-menu-icon" style="color: #6b7280;">@((MarkupString)Icons.DragDrop)</span>
                        <span>@Localizer.L("Editor.Drag & Drop")</span>
                    </button>
                    <div class="rte-menu-divider"></div>
                    <button class="rte-menu-item" @onclick="OnImageGalleryClick">
                        <span class="rte-menu-icon" style="color: #6b7280;">@((MarkupString)Icons.Image)</span>
                        <span>@Localizer.L("Editor.Image Gallery")</span>
                    </button>
                </div>
            </ToolbarDropdown>
            <ToolbarDropdown SvgIcon="@Icons.Video" Tooltip='@Localizer.L("Editor.Insert Video")' @ref="_videoDropdown">
                <div style="padding: 16px; width: 300px;">
                    <div class="rte-form-group" style="margin-bottom: 12px;">
                        <input type="text" class="rte-input" placeholder='@Localizer.L("Editor.Url")' @bind="_videoUrl" @bind:event="oninput" @onkeydown="@(async e => { if (e.Key == "Enter") await OnInsertVideoClick(); })" />
                    </div>
                    <div style="text-align: right;">
                        <button class="rte-btn rte-btn-primary" @onclick="OnInsertVideoClick" disabled="@string.IsNullOrWhiteSpace(_videoUrl)">@Localizer.L("Editor.Insert")</button>
                    </div>
                </div>
            </ToolbarDropdown>
        </div>

        <ToolbarSeparator />

        @* Subscript / Superscript *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.Subscript" Tooltip='@Localizer.L("Editor.Subscript")' IsActive="@State.IsSubscript"
                           OnClick="@(() => ExecuteCommand("subscript"))" />
            <ToolbarButton SvgIcon="@Icons.Superscript" Tooltip='@Localizer.L("Editor.Superscript")' IsActive="@State.IsSuperscript"
                           OnClick="@(() => ExecuteCommand("superscript"))" />
        </div>

        <ToolbarSeparator />

        @* Source Code / Fullscreen *@
        <div class="rte-toolbar-group">
            <ToolbarButton SvgIcon="@Icons.SourceCode" Tooltip='@Localizer.L("Editor.Source Code")' IsActive="@State.IsSourceView"
                           OnClick="@ToggleSourceView" />
            <ToolbarButton SvgIcon="@Icons.Fullscreen" Tooltip='@Localizer.L("Editor.Fullscreen")' IsActive="@State.IsFullscreen"
                           OnClick="@ToggleFullscreen" />
        </div>
    </div>
</div>

@* Dialogs *@
<LinkDialog IsVisible="@_showLinkDialog" OnSubmit="@OnLinkSubmit" OnClose="@(() => { _showLinkDialog = false; })" />
<ImageDialog IsVisible="@_showImageDialog" OnSubmit="@OnImageSubmit" OnClose="@(() => { _showImageDialog = false; })" />
<TableDialog IsVisible="@_showTableDialog" OnSubmit="@OnTableSubmit" OnClose="@(() => { _showTableDialog = false; })" />
<DragDropDialog IsVisible="@_showDragDropDialog" OnSubmit="@OnImageSubmit" OnClose="@(() => { _showDragDropDialog = false; })" />

@* Hidden file inputs for direct system integration *@
<Microsoft.AspNetCore.Components.Forms.InputFile OnChange="HandleImageUpload" accept="image/*" id="@_uploadInputId" style="display:none;" />
<Microsoft.AspNetCore.Components.Forms.InputFile OnChange="HandleImageUpload" accept="image/*" capture="environment" id="@_cameraInputId" style="display:none;" />
