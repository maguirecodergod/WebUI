@namespace LHA.BlazorWasm.Components.RichTextEditor.Components

@if (IsVisible)
{
    <div class="rte-dialog-overlay" @onclick="Close">
        <div class="rte-dialog" @onclick:stopPropagation>
            <div class="rte-dialog-header">
                <h3>@Localizer.L("Insert Link")</h3>
                <button class="rte-dialog-close" type="button" @onclick="Close">
                    <svg viewBox="0 0 24 24" width="18" height="18"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </button>
            </div>
            <div class="rte-dialog-body">
                <div class="rte-form-group">
                    <label>@Localizer.L("URL")</label>
                    <input type="url" class="rte-input" @bind="Url" placeholder='@Localizer.L("https://example.com")'/>
                </div>
                <div class="rte-form-group">
                    <label>@Localizer.L("Display Text")</label>
                    <input type="text" class="rte-input" @bind="DisplayText" placeholder='@Localizer.L("Link text")'/>
                </div>
                <div class="rte-form-group">
                    <label>@Localizer.L("Title")</label>
                    <input type="text" class="rte-input" @bind="Title" placeholder='@Localizer.L("Tooltip text")'/>
                </div>
                <div class="rte-form-group">
                    <label>
                        <input type="checkbox" @bind="OpenInNewTab"/>
                        @Localizer.L("Open in new tab")
                    </label>
                </div>
            </div>
            <div class="rte-dialog-footer">
                <button class="rte-btn rte-btn-secondary" type="button" @onclick="Close">@Localizer.L("Cancel")</button>
                <button class="rte-btn rte-btn-primary" type="button" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(Url)">@Localizer.L("Insert Link")</button>
            </div>
        </div>
    </div>
}
