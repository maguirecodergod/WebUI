@namespace LHA.BlazorWasm.Components.RichTextEditor.Components

@if (IsVisible)
{
    <div class="rte-dialog-overlay" @onclick="Close">
        <div class="rte-dialog" @onclick:stopPropagation>
            <div class="rte-dialog-header">
                <h3>@Localizer.L("Editor.Insert Link")</h3>
                <Button Style="ButtonStyle.Link" Class="rte-dialog-close" OnClick="Close">
                    <svg viewBox="0 0 24 24" width="18" height="18"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </Button>
            </div>
            <div class="rte-dialog-body">
                <div class="rte-form-group">
                    <label>@Localizer.L("Editor.URL")</label>
                    <input type="url" class="rte-input" @bind="Url" placeholder='@Localizer.L("Editor.https://example.com")'/>
                </div>
                <div class="rte-form-group">
                    <label>@Localizer.L("Editor.Display Text")</label>
                    <input type="text" class="rte-input" @bind="DisplayText" placeholder='@Localizer.L("Editor.Link text")'/>
                </div>
                <div class="rte-form-group">
                    <label>@Localizer.L("Editor.Title")</label>
                    <input type="text" class="rte-input" @bind="Title" placeholder='@Localizer.L("Editor.Tooltip text")'/>
                </div>
                <div class="rte-form-group">
                    <label>
                        <input type="checkbox" @bind="OpenInNewTab"/>
                        @Localizer.L("Editor.Open in new tab")
                    </label>
                </div>
            </div>
            <div class="rte-dialog-footer">
                <Button Style="ButtonStyle.Secondary" OnClick="Close">@Localizer.L("Editor.Cancel")</Button>
                <Button Style="ButtonStyle.Primary" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(Url)">@Localizer.L("Editor.Insert Link")</Button>
            </div>
        </div>
    </div>
}
