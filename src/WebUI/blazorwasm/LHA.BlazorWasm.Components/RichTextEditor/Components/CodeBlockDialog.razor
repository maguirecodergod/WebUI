@namespace LHA.BlazorWasm.Components.RichTextEditor.Components

@if (IsVisible)
{
    <div class="rte-dialog-overlay" @onclick="Close">
        <div class="rte-dialog rte-code-dialog" @onclick:stopPropagation>
            <div class="rte-dialog-header">
                <div class="rte-dialog-title-wrapper">
                    <span class="rte-dialog-icon">@((MarkupString)Icons.SourceCode)</span>
                    <h3>@Localizer.L("Editor.Insert Code Block")</h3>
                </div>
                <Button Style="ButtonStyle.Link" Class="rte-dialog-close" OnClick="Close">
                    <svg viewBox="0 0 24 24" width="18" height="18"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </Button>
            </div>
            
            <div class="rte-dialog-body">
                <div class="rte-form-group">
                    <label>@Localizer.L("Editor.Language")</label>
                    <Select TValue="string" 
                            Options="@LanguageOptions" 
                            @bind-Value="Language"
                            Placeholder='@Localizer.L("Editor.Select Language")' />
                </div>
                
                <div class="rte-form-group">
                    <div class="rte-code-editor-wrapper">
                        <div class="rte-code-editor-header">
                            <span class="rte-code-editor-tag">@Language.ToUpper()</span>
                            <span class="rte-code-editor-dots">
                                <span></span><span></span><span></span>
                            </span>
                        </div>
                        <textarea class="rte-code-textarea" 
                                  @bind="Code" 
                                  @bind:event="oninput"
                                  spellcheck="false"
                                  placeholder='@Localizer.L("Editor.Paste your code here...")'></textarea>
                    </div>
                </div>
            </div>
            
            <div class="rte-dialog-footer">
                <Button Style="ButtonStyle.Secondary" OnClick="Close">@Localizer.L("Editor.Cancel")</Button>
                <Button Style="ButtonStyle.Primary" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(Code)">@Localizer.L("Editor.Insert Code")</Button>
            </div>
        </div>
    </div>
}
