@namespace LHA.BlazorWasm.Components.RichTextEditor.Components

<div class="rte-status-bar">
    <div class="rte-element-path">
        @if (!string.IsNullOrEmpty(ElementPath))
        {
            @((MarkupString)ElementPath)
        }
    </div>
    <div class="rte-status-info">
        <span class="rte-word-count">@Localizer.L("Words"): @WordCount</span>
        <span class="rte-char-count">@Localizer.L("Chars"): @CharCount</span>
        <LHA.BlazorWasm.Components.Tooltip.Tooltip Text='@Localizer.L("Clear Content")' Style="display: inline-flex; margin-left: 12px; cursor: pointer;">
            <div @onclick="HandleClearContent" style="color: var(--bs-danger, #dc3545);">
                @((MarkupString)Icons.Trash)
            </div>
        </LHA.BlazorWasm.Components.Tooltip.Tooltip>
    </div>
</div>

@code {
    [Parameter] public int WordCount { get; set; }
    [Parameter] public int CharCount { get; set; }
    [Parameter] public string ElementPath { get; set; } = "";
    [Parameter] public EventCallback OnClearContent { get; set; }

    private async Task HandleClearContent()
    {
        if (OnClearContent.HasDelegate)
        {
            await OnClearContent.InvokeAsync();
        }
    }
}
