@namespace LHA.BlazorWasm.Components.Select
@typeparam TValue
@using Microsoft.AspNetCore.Components.Web
@using LHA.BlazorWasm.Components.Skeleton

<div class="select-wrapper @Class" style="@Style" @onfocusout="OnFocusOut" @onmousedown="HandleInternalMouseDown"
     @onkeydown="HandleKeyDown" tabindex="0" role="combobox" aria-expanded="@State.IsOpen.ToString().ToLower()"
     aria-haspopup="listbox">
    
    <div class="select-input-container @(State.IsOpen ? "active" : "") @(Disabled ? "disabled" : "")"
         @onclick="ToggleDropdown">
        
        <div class="select-value">
            @if (IsSingleMode)
            {
                if (HasValue)
                {
                    if (ValueTemplate != null)
                    {
                        @ValueTemplate(Value)
                    }
                    else
                    {
                        @GetLabel(Value)
                    }
                }
                else
                {
                    <span class="select-placeholder">@Placeholder</span>
                }
            }
            else
            {
                if (Values != null && Values.Any())
                {
                    @foreach (var val in Values)
                    {
                        <div class="select-tag" @onclick:stopPropagation="true">
                            <span class="select-tag-label">@GetLabel(val)</span>
                            @if (!Disabled && !ReadOnly)
                            {
                                <span class="select-tag-remove" @onclick="() => RemoveValue(val)">&times;</span>
                            }
                        </div>
                    }
                }
                else
                {
                    <span class="select-placeholder">@Placeholder</span>
                }
            }
        </div>

        <div class="select-actions">
            @if (ShowClear && HasAnyValue && !Disabled && !ReadOnly)
            {
                <span class="select-clear" @onclick="ClearAsync" @onclick:stopPropagation="true">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </span>
            }
            <div class="select-arrow-container">
                <svg class="select-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </div>
        </div>
    </div>

    <div class="select-dropdown @(State.IsOpen ? "open" : "")" @onclick:stopPropagation="true">
        @if (Searchable)
        {
            <SelectSearch Placeholder="Search..." SearchText="@State.SearchText" OnSearch="HandleSearch" />
        }

        @if (State.IsLoading)
        {
            <div class="select-loading-placeholder">
                <div style="padding: 10px 12px; display: flex; align-items: center; gap: 10px;">
                    <LHA.BlazorWasm.Components.Skeleton.Skeleton IsLoading="true" Width="20px" Height="20px"
                                                                 Variant="SkeletonVariant.Circular" />
                    <LHA.BlazorWasm.Components.Skeleton.Skeleton IsLoading="true" Width="70%" Height="14px" />
                </div>
                <div style="padding: 10px 12px; display: flex; align-items: center; gap: 10px;">
                    <LHA.BlazorWasm.Components.Skeleton.Skeleton IsLoading="true" Width="20px" Height="20px"
                                                                 Variant="SkeletonVariant.Circular" />
                    <LHA.BlazorWasm.Components.Skeleton.Skeleton IsLoading="true" Width="45%" Height="14px" />
                </div>
                <div style="padding: 10px 12px; display: flex; align-items: center; gap: 10px;">
                    <LHA.BlazorWasm.Components.Skeleton.Skeleton IsLoading="true" Width="20px" Height="20px"
                                                                 Variant="SkeletonVariant.Circular" />
                    <LHA.BlazorWasm.Components.Skeleton.Skeleton IsLoading="true" Width="60%" Height="14px" />
                </div>
            </div>
        }
        else if (OnLoadPage == null && !FilteredOptions.Any())
        {
            <div class="select-no-data">No data found</div>
        }
        else
        {
            <SelectVirtualList TValue="TValue" ItemsProvider="State.ItemsProvider" State="State"
                               MaxHeight="@MaxDropdownHeight" IsSelected="IsOptionSelected" IsFocused="IsOptionFocused"
                               OnSelect="SelectItemAsync" OptionTemplate="OptionTemplate" />
        }
    </div>
</div>
