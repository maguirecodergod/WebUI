@namespace LHA.BlazorWasm.Components.Select

<div class="select-item @(IsSelected ? "selected" : "") @(IsFocused ? "focused" : "") @(Disabled ? "disabled" : "")"
     role="option"
     aria-selected="@(IsSelected ? "true" : "false")"
     aria-disabled="@(Disabled ? "true" : "false")"
     @onclick="HandleClick"
     @onclick:stopPropagation="true">
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else
    {
        <div class="d-flex align-items-center w-100">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <i class="@Icon me-2 opacity-75"></i>
            }
            <div class="flex-grow-1">
                <div class="select-item-label">@Label</div>
                @if (!string.IsNullOrEmpty(Description))
                {
                    <div class="select-item-description small opacity-50">@Description</div>
                }
            </div>
            @if (IsSelected)
            {
                <i class="bi bi-check2 ms-2 text-primary"></i>
            }
        </div>
    }
</div>
