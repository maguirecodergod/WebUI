@namespace LHA.BlazorWasm.Components.Section
<section class="@GetCssClass()" style="@Style" role="region" aria-expanded="@IsExpanded.ToString().ToLowerInvariant()">
    @if (!string.IsNullOrWhiteSpace(Title) || Collapsible)
    {
        <div class="section-header" @onclick="ToggleAsync">
            <div class="section-header-left">
                @if (!string.IsNullOrWhiteSpace(Icon))
                {
                    <span class="section-icon" aria-hidden="true">@Icon</span>
                }
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h3 class="section-title">@Title</h3>
                }
            </div>
            @if (Collapsible)
            {
                <span class="section-toggle" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" 
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </span>
            }
        </div>
    }

    <div class="section-content-wrapper">
        <div class="section-content">
            @ChildContent
        </div>
    </div>
</section>
