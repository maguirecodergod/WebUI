@namespace LHA.BlazorWasm.Components.Pickers.DateTimeRangePicker
@using LHA.BlazorWasm.Components.Buttons
@using LHA.BlazorWasm.Components.Pickers.Core
@typeparam TInner
@inherits PickerBase<DateRange<TInner>>

<div class="picker-wrapper @Class" style="@Style" @onfocusout="OnFocusOut" @onmousedown="HandleInternalMouseDown">
    
    <div class="picker-input-container @(State.IsOpen ? "active" : "") @(Disabled ? "disabled" : "")"
         @onclick="TogglePopup">
        <input type="text" class="picker-input" placeholder="@Placeholder" value="@FormattedValue" readonly
               disabled="@Disabled" />
               
        <div class="picker-icon">
            <i class="fas fa-calendar-check"></i>
        </div>
        
        @if (ShowClear && Value.HasStart && !Disabled && !ReadOnly)
        {
            <button type="button" class="picker-clear" @onclick="ClearAsync" @onclick:stopPropagation="true">
                &times;
            </button>
        }
    </div>

    <PickerPopup IsOpen="State.IsOpen">
        <div class="range-layout">
            
            <!-- Left Panel: Start Date & Time -->
            <div class="datetime-panel">
                <div class="panel-header">@LocalizationService.L("DateTimeRangePicker.Start")</div>
                <div class="datetime-split">
                    <CalendarView State="StartState" 
                                  SelectedDate="RangeConverter.MapRange(_tempValue).Start" 
                                  Range="ConvertToLegacyRange(_tempValue)"
                                  OnDateSelected="(d) => HandleDateSelected(d, true)" />
                                  
                    <div class="split-divider"></div>
                    
                    <TimeView State="StartState" Is24Hour="Is24Hour" OnInteraction="HandleTimeChanged" />
                </div>
            </div>
            
            <div class="panel-divider"></div>
            
            <!-- Right Panel: End Date & Time -->
            <div class="datetime-panel">
                <div class="panel-header">@LocalizationService.L("DateTimeRangePicker.End")</div>
                <div class="datetime-split">
                    <CalendarView State="EndState" 
                                  SelectedDate="RangeConverter.MapRange(_tempValue).End" 
                                  Range="ConvertToLegacyRange(_tempValue)"
                                  OnDateSelected="(d) => HandleDateSelected(d, false)" />
                                  
                    <div class="split-divider"></div>
                    
                    <TimeView State="EndState" Is24Hour="Is24Hour" OnInteraction="HandleTimeChanged" />
                </div>
            </div>
            
        </div>
        
        <div class="range-actions">
            <Button Type="ButtonType.Button" Class="btn-confirm" Disabled="@(!_tempValue.IsComplete)"
                    OnClick="ConfirmSelection">
                @ComputedConfirmText
            </Button>
        </div>
    </PickerPopup>
</div>
