@namespace LHA.BlazorWasm.Components.Pickers.DatePicker
@using LHA.BlazorWasm.Components.Pickers.Core
@typeparam TValue
@inherits PickerBase<TValue>

<div class="picker-wrapper @Class" style="@Style" @onfocusout="OnFocusOut" 
     @onmousedown="HandleInternalInteraction" @ontouchstart="HandleInternalInteraction">
    
    <div class="picker-input-container @(State.IsOpen ? "active" : "") @(Disabled ? "disabled" : "") @ValidationClass"
         @onclick="TogglePopup">
        <input type="text" class="picker-input" placeholder="@EffectivePlaceholder" value="@FormattedValue" readonly
               disabled="@Disabled" />
               
        <div class="picker-icon">
            <i class="fas fa-calendar-alt"></i>
        </div>
        
        @if (ShowClear && Value != null && !Disabled && !ReadOnly)
        {
            <button type="button" class="picker-clear" @onclick="ClearAsync" @onclick:stopPropagation="true">
                <i class="fas fa-times-circle"></i>
            </button>
        }
    </div>

    <ValidationMessage Status="CValidationStatus" Message="@ValidationMessage" />

    <PickerPopup IsOpen="State.IsOpen">
        <CalendarView State="State" 
                      SelectedDate="@EffectiveConverter.ToDateTime(Value)" 
                      OnDateSelected="HandleDateSelected"
                      Min="Min"
                      Max="Max"
                      DisabledDateFunc="DisabledDateFunc" />
    </PickerPopup>
</div>
