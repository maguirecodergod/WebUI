@namespace LHA.BlazorWasm.Components.Pickers.DateRangePicker
@using LHA.BlazorWasm.Components.Pickers.Core
@typeparam TInner
@inherits PickerBase<DateRange<TInner>>

<div class="picker-wrapper @Class" style="@Style" @onfocusout="OnFocusOut" @onmousedown="HandleInternalMouseDown">
    
    <div class="picker-input-container @(State.IsOpen ? "active" : "") @(Disabled ? "disabled" : "") @ValidationClass" @onclick="TogglePopup">
        <input type="text" 
               class="picker-input" 
               placeholder="@Placeholder"
               value="@FormattedValue"
               readonly
               disabled="@Disabled" />
               
        <div class="picker-icon">
            <i class="fas fa-calendar-alt"></i>
        </div>
        
        @if (ShowClear && Value.HasStart && !Disabled && !ReadOnly)
        {
            <button type="button" class="picker-clear" @onclick="ClearAsync" @onclick:stopPropagation="true">
                <i class="fas fa-times-circle"></i>
            </button>
        }
    </div>

    <ValidationMessage Status="ValidationStatus" Message="@ValidationMessage" />

    <PickerPopup IsOpen="State.IsOpen" Class="date-range-popup">
        <div class="range-layout">
            <div class="calendar-panel">
                <CalendarView State="LeftState" 
                               SelectedDate="RangeConverter.MapRange(_tempValue).Start" 
                               Range="ConvertToLegacyRange(_tempValue)"
                               OnDateSelected="HandleDateSelected" />
            </div>
            
            <div class="calendar-panel">
                <CalendarView State="RightState" 
                               SelectedDate="RangeConverter.MapRange(_tempValue).End" 
                               Range="ConvertToLegacyRange(_tempValue)"
                               OnDateSelected="HandleDateSelected" />
            </div>
        </div>
        
        <div class="range-actions">
            <button type="button" class="btn-confirm" disabled="@(!_tempValue.IsComplete)" @onclick="ConfirmSelection">
                @ConfirmText
            </button>
        </div>
    </PickerPopup>
</div>
