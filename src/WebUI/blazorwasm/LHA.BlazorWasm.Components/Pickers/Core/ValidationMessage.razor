@namespace LHA.BlazorWasm.Components.Pickers.Core

@if (!string.IsNullOrEmpty(Message))
{
    <div class="validation-msg @StatusClass">
        <i class="@IconClass"></i>
        <span>@Message</span>
    </div>
}

@code {
    [Parameter] public CValidationStatus Status { get; set; } = CValidationStatus.None;
    [Parameter] public string? Message { get; set; }

    private string StatusClass => Status switch
    {
        CValidationStatus.Success => "success",
        CValidationStatus.Warning => "warning",
        CValidationStatus.Error => "error",
        _ => ""
    };

    private string IconClass => Status switch
    {
        CValidationStatus.Success => "fas fa-check-circle",
        CValidationStatus.Warning => "fas fa-exclamation-triangle",
        CValidationStatus.Error => "fas fa-exclamation-circle",
        _ => ""
    };
}
