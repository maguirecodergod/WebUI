@namespace LHA.BlazorWasm.Components.Pickers.Core
@inject LHA.BlazorWasm.Services.Localization.ILocalizationService LocalizationService

<div class="time-view">
    <div class="time-selectors">
        <div class="time-unit">
            <select class="time-select" @bind="State.SelectedHour" @bind:after="OnTimeChanged">
                @for (int i = 0; i < (Is24Hour ? 24 : 12); i++)
                {
                    var val = !Is24Hour && i == 0 ? 12 : i;
                    <option value="@i">@val.ToString("00")</option>
                }
            </select>
        </div>
        
        <span class="time-separator">:</span>
        
        <div class="time-unit">
            <select class="time-select" @bind="State.SelectedMinute" @bind:after="OnTimeChanged">
                @for (int i = 0; i < 60; i++)
                {
                    <option value="@i">@i.ToString("00")</option>
                }
            </select>
        </div>

        @if (!Is24Hour)
        {
            <div class="ampm-toggle">
                <button type="button" class="@(State.AmPm == "AM" ? "active" : "")" @onclick="@(() => SetAmPm("AM"))">
                    @LocalizationService.L("Time.AM")
                </button>
                <button type="button" class="@(State.AmPm == "PM" ? "active" : "")" @onclick="@(() => SetAmPm("PM"))">
                    @LocalizationService.L("Time.PM")
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public PickerState State { get; set; } = default!;
    [Parameter] public bool Is24Hour { get; set; } = false;
    [Parameter] public EventCallback OnInteraction { get; set; }

    private async Task OnTimeChanged()
    {
        await OnInteraction.InvokeAsync();
    }

    private async Task SetAmPm(string value)
    {
        State.AmPm = value;
        await OnInteraction.InvokeAsync();
    }
}
