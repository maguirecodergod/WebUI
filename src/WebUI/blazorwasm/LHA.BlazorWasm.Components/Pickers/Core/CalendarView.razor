@namespace LHA.BlazorWasm.Components.Pickers.Core
@using System.Globalization
@inject LHA.BlazorWasm.Services.Localization.ILocalizationService LocalizationService

<div class="calendar">
    <div class="calendar-header">
        <button type="button" class="nav-btn" @onclick="PrevMonth">
            <i class="fas fa-chevron-left"></i>
        </button>
        <div class="current-month-selects">
            <select class="header-select month-select" @bind="CurrentMonthVal">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i">@LocalizationService.L($"Months.{i}")</option>
                }
            </select>
            <select class="header-select year-select" @bind="CurrentYearVal">
                @for (int year = DateTime.Today.Year - 100; year <= DateTime.Today.Year + 50; year++)
                {
                    <option value="@year">@year</option>
                }
            </select>
        </div>
        <button type="button" class="nav-btn" @onclick="NextMonth">
            <i class="fas fa-chevron-right"></i>
        </button>
    </div>

    <div class="calendar-grid">
        @foreach (var dayName in GetShortDaysOfWeek())
        {
            <div class="calendar-day-name">@dayName</div>
        }

        @foreach (var date in _grid)
        {
            var isCurrentMonth = date.Month == State.CurrentMonth.Month;
            var isSelected = SelectedDate.HasValue && DateUtils.IsSameDay(date, SelectedDate.Value);
            var isToday = DateUtils.IsSameDay(date, DateTime.Today);
            var isInRange = Range.HasValue && DateUtils.IsBetween(date, Range.Value.Start, Range.Value.End);
            var isRangeStart = Range.HasValue && DateUtils.IsSameDay(date, Range.Value.Start);
            var isRangeEnd = Range.HasValue && DateUtils.IsSameDay(date, Range.Value.End);
            
            var isDisabled = (Min.HasValue && date.Date < Min.Value.Date) || 
                             (Max.HasValue && date.Date > Max.Value.Date) || 
                             (DisabledDateFunc?.Invoke(date) ?? false);

            var dayClass = $"calendar-day {(isCurrentMonth ? "" : "other-month")} " +
                           $"{(isSelected ? "selected" : "")} " +
                           $"{(isToday ? "today" : "")} " +
                           $"{(isInRange ? "in-range" : "")} " +
                           $"{(isRangeStart ? "range-start" : "")} " +
                           $"{(isRangeEnd ? "range-end" : "")} " +
                           $"{(isDisabled ? "disabled" : "")}";

            <button type="button" class="@dayClass" @onclick="() => SelectDate(date)" disabled="@isDisabled">
                @date.Day
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public PickerState State { get; set; } = default!;
    [Parameter] public DateTime? SelectedDate { get; set; }
    [Parameter] public DateRange? Range { get; set; }
    [Parameter] public DateTime? Min { get; set; }
    [Parameter] public DateTime? Max { get; set; }
    [Parameter] public Func<DateTime, bool>? DisabledDateFunc { get; set; }
    [Parameter] public EventCallback<DateTime> OnDateSelected { get; set; }

    private List<DateTime> _grid = new();

    private int CurrentMonthVal
    {
        get => State.CurrentMonth.Month;
        set
        {
            State.CurrentMonth = new DateTime(State.CurrentMonth.Year, value, 1);
            RefreshGrid();
        }
    }

    private int CurrentYearVal
    {
        get => State.CurrentMonth.Year;
        set
        {
            State.CurrentMonth = new DateTime(value, State.CurrentMonth.Month, 1);
            RefreshGrid();
        }
    }

    protected override void OnParametersSet()
    {
        RefreshGrid();
    }

    private void RefreshGrid()
    {
        _grid = DateUtils.GenerateCalendarGrid(State.CurrentMonth);
    }

    private void PrevMonth()
    {
        State.CurrentMonth = State.CurrentMonth.AddMonths(-1);
        RefreshGrid();
    }

    private void NextMonth()
    {
        State.CurrentMonth = State.CurrentMonth.AddMonths(1);
        RefreshGrid();
    }

    private async Task SelectDate(DateTime date)
    {
        await OnDateSelected.InvokeAsync(date);
    }

    private string[] GetShortDaysOfWeek()
    {
        // Sunday first sequence
        return new[] { 
            LocalizationService.L("Calendar.Sun"), 
            LocalizationService.L("Calendar.Mon"), 
            LocalizationService.L("Calendar.Tue"), 
            LocalizationService.L("Calendar.Wed"), 
            LocalizationService.L("Calendar.Thu"), 
            LocalizationService.L("Calendar.Fri"), 
            LocalizationService.L("Calendar.Sat") 
        };
    }
}
