    "version": "0.2.0",
    "configurations": [
        {
            "name": "LHA.Account.HttpApi.Host",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "",
            "program": "${workspaceFolder}/src/services/account/LHA.Account.HttpApi.Host/bin/Debug/net10.0/LHA.Account.HttpApi.Host.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/services/account/LHA.Account.HttpApi.Host",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}