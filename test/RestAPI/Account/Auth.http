@baseUrl = https://localhost:7150
@apiVersion = 1

### 1. Register a new user
# @name Register
POST {{baseUrl}}/api/v{{apiVersion}}/identity/auth/register
Content-Type: application/json

{
    "userName": "newuser",
    "email": "newuser@example.com",
    "password": "Password123!",
    "name": "New",
    "surname": "User",
    "phoneNumber": "0987654321",
    "lockoutEnabled": true,
    "roleIds": []
}

###

### 2. Login (Admin)
# @name LoginAdmin
POST {{baseUrl}}/api/v{{apiVersion}}/identity/auth/login
Content-Type: application/json

{
    "userNameOrEmail": "admin",
    "password": "Admin@123456"
}

###

### 3. Login (New User)
# @name Login
POST {{baseUrl}}/api/v{{apiVersion}}/identity/auth/login
Accept-Language: vi
Content-Type: application/json

{
    "userNameOrEmail": "newuser",
    "password": "Password123!"
}

###

@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..mWr9Bq5I3s7fWXE4Qq5KkRGK0TMpwSXUdCkb8dvEr5M
@refreshToken = {{Login.response.body.data.refreshToken}}

### 4. Refresh Token
# @name RefreshToken
POST {{baseUrl}}/api/v{{apiVersion}}/identity/auth/refresh
Content-Type: application/json

{
    "refreshToken": "{{refreshToken}}"
}

###

### 5. Get Current User Info
# @name GetMe
GET {{baseUrl}}/api/v{{apiVersion}}/identity/auth/me
Authorization: Bearer {{accessToken}}



### 6. Get Audit Logs
# @name GetAuditLogs
GET {{baseUrl}}/api/v{{apiVersion}}/audit-logs?skipCount=0&maxResultCount=100
Authorization: Bearer {{accessToken}}