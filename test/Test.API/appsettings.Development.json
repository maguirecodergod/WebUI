{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],
    "WriteTo": [
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            {
              "key": "app",
              "value": "order-api"
            },
            {
              "key": "env",
              "value": "dev"
            },
            {
              "key": "service",
              "value": "checkout"
            }
          ],
          "propertiesAsLabels": [
            "Level",
            "TraceId",
            "TenantId"
          ]
        }
      },
      {
        "Name": "Console"
      }
    ]
  }
}
